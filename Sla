--[[
	CrystalUILib
	Biblioteca de UI gerada a partir do design "Crystal" (Window/Main/Tabs/TabPages).
	Uso básico:

		local Lib = loadstring(readfile("CrystalUILib.lua"))() -- ou require(modulo)
		local Window = Lib.new("Crystal")

		local Home = Window:CreateTab("Home", "rbxassetid://73551258618338", "View your and server's information")
		Home:AddLabel("Bem-vindo")
		Home:AddButton("Rejoin", function() print("rejoin") end)
		Home:AddToggle("Auto Farm", false, function(state) print(state) end)
		Home:AddSlider("Velocidade", 0, 100, 50, function(v) print(v) end)
		Home:AddDropdown("Modo", {"Passivo","Agressivo"}, function(opt) print(opt) end)
]]

local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")

local Library = {}
Library.__index = Library

local TabMethods = {}
TabMethods.__index = TabMethods

-- ===== helpers =====

local function new(class, props, children)
	local inst = Instance.new(class)
	for k, v in pairs(props or {}) do
		inst[k] = v
	end
	for _, child in ipairs(children or {}) do
		child.Parent = inst
	end
	return inst
end

local function applyStrokeGradient(target, c1, c2)
	local stroke = new("UIStroke", { Color = Color3.new(1, 1, 1), ApplyStrokeMode = Enum.ApplyStrokeMode.Border })
	stroke.Parent = target
	new("UIGradient", {
		Color = ColorSequence.new(c1, c2),
		Rotation = -90,
		Transparency = NumberSequence.new(0.1),
	}).Parent = stroke
	return stroke
end

local function card(parent, height, order)
	local c = new("Frame", {
		BackgroundColor3 = Color3.fromRGB(20, 20, 20),
		BackgroundTransparency = 0.5,
		BorderSizePixel = 0,
		Size = UDim2.new(0.88, 0, 0, height or 50),
		LayoutOrder = order or 0,
	})
	new("UICorner", { CornerRadius = UDim.new(0, 10) }).Parent = c
	applyStrokeGradient(c, Color3.fromRGB(23, 23, 23), Color3.fromRGB(36, 36, 36))
	return c
end

-- ===== Window =====

function Library.new(title, subtitle)
	local self = setmetatable({}, Library)
	self.Tabs = {}
	self.CurrentTab = nil

	self.ScreenGui = new("ScreenGui", {
		Name = "CrystalUI",
		ResetOnSpawn = false,
		ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
	})
	local ok = pcall(function()
		self.ScreenGui.Parent = CoreGui
	end)
	if not ok then
		self.ScreenGui.Parent = game.Players.LocalPlayer:WaitForChild("PlayerGui")
	end

	self.Window = new("Frame", {
		Name = "Window",
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position = UDim2.fromScale(0.5, 0.5),
		Size = UDim2.fromScale(0.4, 0.5),
		BackgroundColor3 = Color3.fromRGB(23, 23, 23),
		BackgroundTransparency = 0.1,
		BorderSizePixel = 0,
		ClipsDescendants = true,
	})
	self.Window.Parent = self.ScreenGui
	new("UICorner", { CornerRadius = UDim.new(0.045, 0) }).Parent = self.Window
	applyStrokeGradient(self.Window, Color3.fromRGB(23, 23, 23), Color3.fromRGB(66, 66, 66))

	local main = new("Frame", { Name = "Main", BackgroundTransparency = 1, Size = UDim2.fromScale(1, 1) })
	main.Parent = self.Window

	local titleBar = new("Frame", { Name = "Title", BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0.15, 0) })
	titleBar.Parent = main

	new("TextLabel", {
		Name = "Name",
		AnchorPoint = Vector2.new(0.5, 1),
		Position = UDim2.new(0.5, 0, 0.8, 0),
		Size = UDim2.new(0.6, 0, 0.35, 0),
		BackgroundTransparency = 1,
		Text = title or "Crystal",
		TextColor3 = Color3.fromRGB(254, 253, 255),
		TextScaled = true,
		Font = Enum.Font.GothamMedium,
	}).Parent = titleBar

	if subtitle then
		new("TextLabel", {
			Name = "Subtitle",
			AnchorPoint = Vector2.new(0.5, 0),
			Position = UDim2.new(0.5, 0, 0.85, 0),
			Size = UDim2.new(0.7, 0, 0.15, 0),
			BackgroundTransparency = 1,
			Text = subtitle,
			TextColor3 = Color3.fromRGB(174, 174, 174),
			TextScaled = true,
			Font = Enum.Font.Gotham,
		}).Parent = titleBar
	end

	self.TabsContainer = new("ScrollingFrame", {
		Name = "Tabs",
		Position = UDim2.new(0, 0, 0.15, 0),
		Size = UDim2.new(1, 0, 0.85, 0),
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		ScrollBarThickness = 0,
		AutomaticCanvasSize = Enum.AutomaticSize.Y,
		CanvasSize = UDim2.new(0, 0, 0, 0),
		ScrollingDirection = Enum.ScrollingDirection.Y,
	})
	self.TabsContainer.Parent = main
	new("UIListLayout", {
		Padding = UDim.new(0.025, 0),
		HorizontalAlignment = Enum.HorizontalAlignment.Center,
		SortOrder = Enum.SortOrder.LayoutOrder,
	}).Parent = self.TabsContainer

	self.Drag = new("TextButton", {
		Name = "Drag",
		AnchorPoint = Vector2.new(0.5, 0),
		Position = UDim2.new(0.5, 0, 0.007, 0),
		Size = UDim2.new(0.3, 0, 0.045, 0),
		BackgroundTransparency = 1,
		Text = ". . .",
		TextColor3 = Color3.fromRGB(175, 175, 175),
		Font = Enum.Font.GothamBlack,
		TextScaled = true,
		AutoButtonColor = false,
	})
	self.Drag.Parent = self.Window

	self.TabPages = new("Folder", { Name = "TabPages" })
	self.TabPages.Parent = self.Window

	self:_setupDrag()

	return self
end

function Library:_setupDrag()
	local frame = self.Window
	local dragging, dragInput, dragStart, startPos

	self.Drag.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = frame.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)

	self.Drag.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if input == dragInput and dragging then
			local delta = input.Position - dragStart
			frame.Position = UDim2.new(
				startPos.X.Scale, startPos.X.Offset + delta.X,
				startPos.Y.Scale, startPos.Y.Offset + delta.Y
			)
		end
	end)
end

function Library:SelectTab(tab)
	if self.CurrentTab then
		self.CurrentTab.Page.Visible = false
	end
	tab.Page.Visible = true
	self.CurrentTab = tab
end

function Library:CreateTab(name, icon, description)
	local index = #self.Tabs + 1

	local button = new("TextButton", {
		Name = name,
		Text = "",
		AutoButtonColor = false,
		BackgroundColor3 = Color3.fromRGB(20, 20, 20),
		BackgroundTransparency = 0.5,
		BorderSizePixel = 0,
		LayoutOrder = index,
		Size = UDim2.new(0.88, 0, 0.17, 0),
	})
	button.Parent = self.TabsContainer
	new("UICorner", { CornerRadius = UDim.new(0.215, 0) }).Parent = button
	applyStrokeGradient(button, Color3.fromRGB(23, 23, 23), Color3.fromRGB(36, 36, 36))

	if icon then
		new("ImageLabel", {
			Name = "Icon",
			Image = icon,
			ImageColor3 = Color3.fromRGB(234, 234, 234),
			BackgroundTransparency = 1,
			ScaleType = Enum.ScaleType.Fit,
			AnchorPoint = Vector2.new(0, 0.5),
			Position = UDim2.new(0.043, 0, 0.5, 0),
			Size = UDim2.new(0.105, 0, 0.575, 0),
		}).Parent = button
	end

	new("TextLabel", {
		Name = "Title",
		Text = name,
		TextColor3 = Color3.fromRGB(234, 234, 234),
		TextScaled = true,
		TextWrapped = true,
		TextXAlignment = Enum.TextXAlignment.Left,
		Font = Enum.Font.GothamMedium,
		BackgroundTransparency = 1,
		AnchorPoint = Vector2.new(0, 0.5),
		Position = UDim2.new(icon and 0.192 or 0.06, 0, 0.375, 0),
		Size = UDim2.new(icon and 0.764 or 0.88, 0, 0.275, 0),
	}).Parent = button

	if description then
		new("TextLabel", {
			Name = "Description",
			Text = description,
			TextColor3 = Color3.fromRGB(174, 174, 174),
			TextScaled = true,
			TextWrapped = true,
			TextXAlignment = Enum.TextXAlignment.Left,
			Font = Enum.Font.Gotham,
			BackgroundTransparency = 1,
			AnchorPoint = Vector2.new(0, 0.5),
			Position = UDim2.new(icon and 0.192 or 0.06, 0, 0.6625, 0),
			Size = UDim2.new(icon and 0.764 or 0.88, 0, 0.21, 0),
		}).Parent = button
	end

	local page = new("ScrollingFrame", {
		Name = name,
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = UDim2.fromScale(1, 1),
		Visible = false,
		ScrollBarThickness = 3,
		AutomaticCanvasSize = Enum.AutomaticSize.Y,
		CanvasSize = UDim2.new(0, 0, 0, 0),
	})
	page.Parent = self.TabPages
	new("UIListLayout", {
		Padding = UDim.new(0, 8),
		HorizontalAlignment = Enum.HorizontalAlignment.Center,
		SortOrder = Enum.SortOrder.LayoutOrder,
	}).Parent = page
	new("UIPadding", { PaddingTop = UDim.new(0, 10), PaddingBottom = UDim.new(0, 10) }).Parent = page

	local tab = setmetatable({ Button = button, Page = page, Library = self, _order = 0 }, TabMethods)

	button.MouseButton1Click:Connect(function()
		self:SelectTab(tab)
	end)

	table.insert(self.Tabs, tab)
	if #self.Tabs == 1 then
		self:SelectTab(tab)
	end

	return tab
end

-- ===== Tab components =====

local function nextOrder(tab)
	tab._order += 1
	return tab._order
end

function TabMethods:AddLabel(text)
	local c = card(self.Page, 36, nextOrder(self))
	new("TextLabel", {
		Text = text,
		TextColor3 = Color3.fromRGB(234, 234, 234),
		Font = Enum.Font.Gotham,
		TextSize = 16,
		TextXAlignment = Enum.TextXAlignment.Left,
		BackgroundTransparency = 1,
		Size = UDim2.new(0.9, 0, 1, 0),
		Position = UDim2.new(0.05, 0, 0, 0),
	}).Parent = c
	return c
end

function TabMethods:AddButton(text, callback)
	local c = card(self.Page, 44, nextOrder(self))
	local btn = new("TextButton", {
		Text = text,
		TextColor3 = Color3.fromRGB(234, 234, 234),
		Font = Enum.Font.GothamMedium,
		TextSize = 16,
		BackgroundTransparency = 1,
		Size = UDim2.fromScale(1, 1),
		AutoButtonColor = false,
	})
	btn.Parent = c
	btn.MouseButton1Click:Connect(function()
		if callback then
			callback()
		end
	end)
	return c
end

function TabMethods:AddToggle(text, default, callback)
	local c = card(self.Page, 44, nextOrder(self))
	local state = default and true or false

	new("TextLabel", {
		Text = text,
		TextColor3 = Color3.fromRGB(234, 234, 234),
		Font = Enum.Font.Gotham,
		TextSize = 16,
		TextXAlignment = Enum.TextXAlignment.Left,
		BackgroundTransparency = 1,
		Size = UDim2.new(0.65, 0, 1, 0),
		Position = UDim2.new(0.05, 0, 0, 0),
	}).Parent = c

	local knob = new("TextButton", {
		Text = "",
		AutoButtonColor = false,
		AnchorPoint = Vector2.new(1, 0.5),
		Position = UDim2.new(0.95, 0, 0.5, 0),
		Size = UDim2.new(0, 40, 0, 20),
		BackgroundColor3 = state and Color3.fromRGB(120, 40, 40) or Color3.fromRGB(40, 40, 40),
		BorderSizePixel = 0,
	})
	knob.Parent = c
	new("UICorner", { CornerRadius = UDim.new(1, 0) }).Parent = knob

	local dot = new("Frame", {
		AnchorPoint = Vector2.new(state and 1 or 0, 0.5),
		Position = state and UDim2.new(1, -2, 0.5, 0) or UDim2.new(0, 2, 0.5, 0),
		Size = UDim2.new(0, 16, 0, 16),
		BackgroundColor3 = Color3.fromRGB(230, 230, 230),
		BorderSizePixel = 0,
	})
	dot.Parent = knob
	new("UICorner", { CornerRadius = UDim.new(1, 0) }).Parent = dot

	knob.MouseButton1Click:Connect(function()
		state = not state
		knob.BackgroundColor3 = state and Color3.fromRGB(120, 40, 40) or Color3.fromRGB(40, 40, 40)
		TweenService:Create(dot, TweenInfo.new(0.15), {
			Position = state and UDim2.new(1, -2, 0.5, 0) or UDim2.new(0, 2, 0.5, 0),
			AnchorPoint = Vector2.new(state and 1 or 0, 0.5),
		}):Play()
		if callback then
			callback(state)
		end
	end)

	return c
end

function TabMethods:AddSlider(text, min, max, default, callback)
	local c = card(self.Page, 52, nextOrder(self))
	local value = math.clamp(default or min, min, max)

	local label = new("TextLabel", {
		Text = text .. ": " .. tostring(value),
		TextColor3 = Color3.fromRGB(234, 234, 234),
		Font = Enum.Font.Gotham,
		TextSize = 15,
		TextXAlignment = Enum.TextXAlignment.Left,
		BackgroundTransparency = 1,
		Size = UDim2.new(0.9, 0, 0, 20),
		Position = UDim2.new(0.05, 0, 0, 2),
	})
	label.Parent = c

	local track = new("Frame", {
		BackgroundColor3 = Color3.fromRGB(40, 40, 40),
		BorderSizePixel = 0,
		Size = UDim2.new(0.9, 0, 0, 6),
		Position = UDim2.new(0.05, 0, 0, 32),
	})
	track.Parent = c
	new("UICorner", { CornerRadius = UDim.new(1, 0) }).Parent = track

	local fillScale = (value - min) / (max - min)
	local fill = new("Frame", {
		BackgroundColor3 = Color3.fromRGB(120, 40, 40),
		BorderSizePixel = 0,
		Size = UDim2.new(fillScale, 0, 1, 0),
	})
	fill.Parent = track
	new("UICorner", { CornerRadius = UDim.new(1, 0) }).Parent = fill

	local dragging = false
	local function setFromX(x)
		local rel = math.clamp((x - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
		value = math.floor(min + (max - min) * rel + 0.5)
		fill.Size = UDim2.new(rel, 0, 1, 0)
		label.Text = text .. ": " .. tostring(value)
		if callback then
			callback(value)
		end
	end

	track.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			setFromX(input.Position.X)
		end
	end)
	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			setFromX(input.Position.X)
		end
	end)
	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)

	return c
end

function TabMethods:AddDropdown(text, options, callback)
	local expanded = false
	local c = card(self.Page, 44, nextOrder(self))
	c.ClipsDescendants = true

	local header = new("TextButton", {
		Text = "",
		AutoButtonColor = false,
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 0, 44),
	})
	header.Parent = c

	local label = new("TextLabel", {
		Text = text .. (options[1] and (": " .. options[1]) or ""),
		TextColor3 = Color3.fromRGB(234, 234, 234),
		Font = Enum.Font.GothamMedium,
		TextSize = 16,
		TextXAlignment = Enum.TextXAlignment.Left,
		BackgroundTransparency = 1,
		Size = UDim2.new(0.85, 0, 1, 0),
		Position = UDim2.new(0.05, 0, 0, 0),
	})
	label.Parent = header

	local list = new("Frame", {
		BackgroundTransparency = 1,
		Position = UDim2.new(0, 0, 0, 44),
		Size = UDim2.new(1, 0, 0, #options * 32),
	})
	list.Parent = c
	new("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder }).Parent = list

	for _, opt in ipairs(options) do
		local optBtn = new("TextButton", {
			Text = opt,
			TextColor3 = Color3.fromRGB(200, 200, 200),
			Font = Enum.Font.Gotham,
			TextSize = 14,
			TextXAlignment = Enum.TextXAlignment.Left,
			BackgroundTransparency = 1,
			Size = UDim2.new(1, 0, 0, 32),
		})
		optBtn.Parent = list
		new("UIPadding", { PaddingLeft = UDim.new(0.08, 0) }).Parent = optBtn

		optBtn.MouseButton1Click:Connect(function()
			label.Text = text .. ": " .. opt
			if callback then
				callback(opt)
			end
		end)
	end

	header.MouseButton1Click:Connect(function()
		expanded = not expanded
		local targetHeight = expanded and (44 + #options * 32) or 44
		TweenService:Create(c, TweenInfo.new(0.15), { Size = UDim2.new(0.88, 0, 0, targetHeight) }):Play()
	end)

	return c
end

return Library
