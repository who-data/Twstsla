local Library = {}
Library.__index = Library

function Library.new(config)
    config = config or {}
    local self = setmetatable({}, Library)

    self.Title = config.Title or "Window"
    self.SubTitle = config.SubTitle or ""
    self.Tabs = {}

    self.ScreenGui = make("ScreenGui", {
        Name = config.Name or "UILibrary",
        ResetOnSpawn = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        DisplayOrder = 999,
    }, getScreenGuiParent())

    self.Main = make("CanvasGroup", {
        Name = "Main",
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(0.5, 0, 0.5, 0),
        Size = config.Size or UDim2.new(0, 580, 0, 400),
        BackgroundColor3 = Theme.Background,
        BackgroundTransparency = Theme.CardTransparency,
        BorderSizePixel = 0,
        ClipsDescendants = true,
    }, self.ScreenGui)
    addCorner(self.Main, Theme.CornerBig)
    addStroke(self.Main, 1.5)

    self.TitleBar = make("Frame", {
        Name = "TitleBar",
        Size = UDim2.new(1, 0, 0, 44),
        BackgroundTransparency = 1,
    }, self.Main)

    make("TextLabel", {
        Name = "Title",
        Position = UDim2.new(0, 16, 0, 0),
        Size = UDim2.new(1, -100, 1, 0),
        BackgroundTransparency = 1,
        Font = Theme.Font,
        Text = self.Title,
        TextColor3 = Theme.Text,
        TextSize = 18,
        TextXAlignment = Enum.TextXAlignment.Left,
    }, self.TitleBar)

    if self.SubTitle ~= "" then
        make("TextLabel", {
            Name = "SubTitle",
            Position = UDim2.new(0, 16, 0, 22),
            Size = UDim2.new(1, -100, 0, 16),
            BackgroundTransparency = 1,
            Font = Theme.Font,
            Text = self.SubTitle,
            TextColor3 = Theme.SubText,
            TextSize = 12,
            TextXAlignment = Enum.TextXAlignment.Left,
        }, self.TitleBar)
    end

    local closeBtn = make("TextButton", {
        Name = "Close",
        AnchorPoint = Vector2.new(1, 0),
        Position = UDim2.new(1, -12, 0, 10),
        Size = UDim2.new(0, 26, 0, 26),
        BackgroundColor3 = Theme.BackgroundAlt,
        BackgroundTransparency = 0.5,
        Font = Theme.Font,
        Text = "X",
        TextColor3 = Theme.Text,
        TextSize = 14,
        AutoButtonColor = false,
    }, self.TitleBar)
    addCorner(closeBtn)
    closeBtn.MouseButton1Click:Connect(function()
        self.ScreenGui:Destroy()
    end)

    local minimizeBtn = make("TextButton", {
        Name = "Minimize",
        AnchorPoint = Vector2.new(1, 0),
        Position = UDim2.new(1, -44, 0, 10),
        Size = UDim2.new(0, 26, 0, 26),
        BackgroundColor3 = Theme.BackgroundAlt,
        BackgroundTransparency = 0.5,
        Font = Theme.Font,
        Text = "_",
        TextColor3 = Theme.Text,
        TextSize = 14,
        AutoButtonColor = false,
    }, self.TitleBar)
    addCorner(minimizeBtn)

    makeDraggable(self.TitleBar, self.Main)

    self.TabHolder = make("Frame", {
        Name = "Tabs",
        Position = UDim2.new(0, 12, 0, 54),
        Size = UDim2.new(0, 130, 1, -66),
        BackgroundTransparency = 1,
    }, self.Main)
    make("UIListLayout", {
        Padding = UDim.new(0, 6),
        SortOrder = Enum.SortOrder.LayoutOrder,
    }, self.TabHolder)

    self.ContentHolder = make("Frame", {
        Name = "Content",
        Position = UDim2.new(0, 154, 0, 54),
        Size = UDim2.new(1, -166, 1, -66),
        BackgroundTransparency = 1,
    }, self.Main)

    -- Minimizar / restaurar
    local minimized = false
    local fullSize = self.Main.Size
    minimizeBtn.MouseButton1Click:Connect(function()
        minimized = not minimized
        if minimized then
            tween(self.Main, { Size = UDim2.new(0, fullSize.X.Offset, 0, 44) }, 0.2)
            self.TabHolder.Visible = false
            self.ContentHolder.Visible = false
        else
            tween(self.Main, { Size = fullSize }, 0.2)
            task.wait(0.05)
            self.TabHolder.Visible = true
            self.ContentHolder.Visible = true
        end
    end)

    -- Container de notificações
    self.NotifyHolder = make("Frame", {
        Name = "Notifications",
        AnchorPoint = Vector2.new(1, 1),
        Position = UDim2.new(1, -20, 1, -20),
        Size = UDim2.new(0, 260, 1, -40),
        BackgroundTransparency = 1,
    }, self.ScreenGui)
    make("UIListLayout", {
        Padding = UDim.new(0, 8),
        VerticalAlignment = Enum.VerticalAlignment.Bottom,
        SortOrder = Enum.SortOrder.LayoutOrder,
    }, self.NotifyHolder)

    return self
end

