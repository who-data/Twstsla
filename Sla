function Library:CreateWindow(cfg)
    cfg = cfg or {}
    local title = cfg.Title or "UILib"
    local subtitle = cfg.Subtitle or ""
    local size = cfg.Size or UDim2.fromOffset(560, 380)
    local toggleKey = cfg.ToggleKey or Enum.KeyCode.RightControl

    local ScreenGui = create("ScreenGui", {
        Name = "UILib_" .. title,
        ResetOnSpawn = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        DisplayOrder = 999,
    })
    ScreenGui.Parent = getGuiParent()
    print("[UILib] Window criada:", title, "| Parent:", ScreenGui.Parent:GetFullName())

    local MainFrame = create("Frame", {
        Name = "MainFrame",
        Size = size,
        Position = UDim2.fromScale(0.5, 0.5),
        AnchorPoint = Vector2.new(0.5, 0.5),
        BackgroundColor3 = Theme.Background,
        BorderSizePixel = 0,
        ClipsDescendants = true,
    }, {corner(6), stroke(Theme.Stroke, 1)})
    MainFrame.Parent = ScreenGui

    -- Topbar
    local Topbar = create("Frame", {
        Name = "Topbar",
        Size = UDim2.new(1, 0, 0, 36),
        BackgroundColor3 = Theme.Panel,
        BorderSizePixel = 0,
    })
    Topbar.Parent = MainFrame
    create("Frame", {Size = UDim2.new(1,0,0,1), Position = UDim2.new(0,0,1,-1), BackgroundColor3 = Theme.Stroke, BorderSizePixel = 0}).Parent = Topbar

    local TitleLabel = create("TextLabel", {
        Text = title,
        Font = Theme.FontBold,
        TextSize = 13,
        TextColor3 = Theme.Text,
        BackgroundTransparency = 1,
        Size = UDim2.new(0.6, 0, 1, 0),
        Position = UDim2.new(0, 12, 0, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
    })
    TitleLabel.Parent = Topbar

    if subtitle ~= "" then
        create("TextLabel", {
            Text = subtitle,
            Font = Theme.Font,
            TextSize = 11,
            TextColor3 = Theme.SubText,
            BackgroundTransparency = 1,
            Size = UDim2.new(0.4, -70, 1, 0),
            Position = UDim2.new(1, -220, 0, 0),
            TextXAlignment = Enum.TextXAlignment.Right,
        }).Parent = Topbar
    end

    local MinBtn = create("TextButton", {
        Size = UDim2.fromOffset(24, 20),
        Position = UDim2.new(1, -60, 0.5, 0),
        AnchorPoint = Vector2.new(0, 0.5),
        BackgroundColor3 = Theme.PanelDark,
        Text = "—",
        Font = Theme.FontBold,
        TextSize = 12,
        TextColor3 = Theme.SubText,
        AutoButtonColor = false,
    }, {corner(4), stroke()})
    MinBtn.Parent = Topbar

    local CloseBtn = create("TextButton", {
        Size = UDim2.fromOffset(24, 20),
        Position = UDim2.new(1, -30, 0.5, 0),
        AnchorPoint = Vector2.new(0, 0.5),
        BackgroundColor3 = Theme.PanelDark,
        Text = "X",
        Font = Theme.FontBold,
        TextSize = 12,
        TextColor3 = Theme.Accent,
        AutoButtonColor = false,
    }, {corner(4), stroke()})
    CloseBtn.Parent = Topbar

    makeDraggable(MainFrame, Topbar)

    -- Sidebar
    local Sidebar = create("Frame", {
        Name = "Sidebar",
        Size = UDim2.new(0, 130, 1, -36),
        Position = UDim2.new(0, 0, 0, 36),
        BackgroundColor3 = Theme.PanelDark,
        BorderSizePixel = 0,
    })
    Sidebar.Parent = MainFrame
    create("Frame", {Size = UDim2.new(0,1,1,0), Position = UDim2.new(1,-1,0,0), BackgroundColor3 = Theme.Stroke, BorderSizePixel = 0}).Parent = Sidebar

    local TabList = create("ScrollingFrame", {
        Size = UDim2.new(1, 0, 1, -10),
        Position = UDim2.new(0, 0, 0, 10),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 2,
        ScrollBarImageColor3 = Theme.Panel,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
    }, {
        create("UIListLayout", {Padding = UDim.new(0, 2), HorizontalAlignment = Enum.HorizontalAlignment.Center}),
        create("UIPadding", {PaddingLeft = UDim.new(0, 6), PaddingRight = UDim.new(0, 6)}),
    })
    TabList.Parent = Sidebar

    local ContentArea = create("ScrollingFrame", {
        Name = "ContentArea",
        Size = UDim2.new(1, -130, 1, -36),
        Position = UDim2.new(0, 130, 0, 36),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 3,
        ScrollBarImageColor3 = Theme.Panel,
        CanvasSize = UDim2.new(0, 0, 0, 0),
    })
    ContentArea.Parent = MainFrame

    local minimized = false
    MinBtn.MouseButton1Click:Connect(function()
        minimized = not minimized
        tween(MainFrame, {Size = minimized and UDim2.fromOffset(size.X.Offset, 36) or size}, 0.2)
    end)
    CloseBtn.MouseButton1Click:Connect(function() ScreenGui.Enabled = false end)

    UserInputService.InputBegan:Connect(function(input, gpe)
        if gpe then return end
        if input.KeyCode == toggleKey then ScreenGui.Enabled = not ScreenGui.Enabled end
    end)

    local Window = {ScreenGui = ScreenGui, MainFrame = MainFrame, Tabs = {}, _firstTab = nil}

    ------------------------------------------------------------
    -- TAB
    ------------------------------------------------------------
    function Window:CreateTab(name)
        local TabButton = create("TextButton", {
            Size = UDim2.new(1, 0, 0, 28),
            BackgroundColor3 = Theme.Panel,
            BackgroundTransparency = 1,
            Text = name,
            Font = Theme.Font,
            TextSize = 12,
            TextColor3 = Theme.SubText,
            AutoButtonColor = false,
        }, {corner(4)})
        TabButton.Parent = TabList

        local TabPage = create("Frame", {
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            Visible = false,
        }, {
            create("UIListLayout", {Padding = UDim.new(0, 8)}),
            create("UIPadding", {PaddingLeft = UDim.new(0, 10), PaddingRight = UDim.new(0, 10), PaddingTop = UDim.new(0, 10), PaddingBottom = UDim.new(0, 10)}),
        })
        TabPage.Parent = ContentArea

        local function selectTab()
            for _, t in pairs(Window.Tabs) do
                t.Page.Visible = false
                tween(t.Button, {BackgroundTransparency = 1, TextColor3 = Theme.SubText}, 0.12)
            end
            TabPage.Visible = true
            tween(TabButton, {BackgroundTransparency = 0, TextColor3 = Theme.Text}, 0.12)
        end
        TabButton.MouseButton1Click:Connect(selectTab)

        local Tab = {Button = TabButton, Page = TabPage}
        Window.Tabs[name] = Tab
        if not Window._firstTab then Window._firstTab = true; selectTab() end

        ------------------------------------------------------------
        -- SECTION (CategoryBox: caixa com borda, header e rows dentro)
        ------------------------------------------------------------
        function Tab:CreateSection(name)
            local Box = create("Frame", {
                Size = UDim2.new(1, 0, 0, 0),
                AutomaticSize = Enum.AutomaticSize.Y,
                BackgroundColor3 = Theme.Panel,
            }, {
                corner(6), stroke(),
                create("UIListLayout", {Padding = UDim.new(0, 4), SortOrder = Enum.SortOrder.LayoutOrder}),
                create("UIPadding", {PaddingLeft = UDim.new(0, 10), PaddingRight = UDim.new(0, 10), PaddingTop = UDim.new(0, 8), PaddingBottom = UDim.new(0, 8)}),
            })
            Box.Parent = TabPage

            create("TextLabel", {
                Text = name,
                Font = Theme.FontBold,
                TextSize = 12,
                TextColor3 = Theme.Text,
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 0, 20),
                TextXAlignment = Enum.TextXAlignment.Left,
            }).Parent = Box

            local Section = {Box = Box}

            -- TOGGLE (switch em pílula, igual ao original)
            function Section:CreateToggle(opt)
                opt = opt or {}
                local flag = opt.Flag or opt.Name
                local state = (opt.Default == true)
                Library.Flags[flag] = state

                local Row = create("TextButton", {
                    Size = UDim2.new(1, 0, 0, 26),
                    BackgroundTransparency = 1,
                    Text = "",
                    AutoButtonColor = false,
                })
                Row.Parent = Box

                create("TextLabel", {
                    Text = opt.Name or "Toggle",
                    Font = Theme.FontBold,
                    TextSize = 12,
                    TextColor3 = Theme.Text,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, -40, 1, 0),
                    Position = UDim2.new(0, 4, 0, 0),
                    TextXAlignment = Enum.TextXAlignment.Left,
                }).Parent = Row

                local Switch = create("Frame", {
                    Size = UDim2.fromOffset(30, 14),
                    Position = UDim2.new(1, -30, 0.5, -7),
                    BackgroundColor3 = state and Theme.Switch or Theme.SwitchOff,
                }, {corner(nil, true), vgradient(Theme.Switch, Color3.fromRGB(160,160,160), 90)})
                Switch.Parent = Row

                local Knob = create("Frame", {
                    Size = UDim2.fromOffset(12, 12),
                    Position = state and UDim2.new(1, -13, 0.5, -6) or UDim2.new(0, 2, 0.5, -6),
                    BackgroundColor3 = state and Theme.Knob or Theme.KnobOff,
                }, {corner(nil, true)})
                Knob.Parent = Switch

                local function setState(v, fireCallback)
                    state = v
                    Library.Flags[flag] = state
                    tween(Switch, {BackgroundColor3 = state and Theme.Switch or Theme.SwitchOff}, 0.15)
                    tween(Knob, {
                        Position = state and UDim2.new(1, -13, 0.5, -6) or UDim2.new(0, 2, 0.5, -6),
                        BackgroundColor3 = state and Theme.Knob or Theme.KnobOff,
                    }, 0.15)
                    if fireCallback ~= false and opt.Callback then opt.Callback(state) end
                end

                Row.MouseButton1Click:Connect(function() setState(not state) end)
                Library.Elements[flag] = {Set = function(v) setState(v, false) end}
                if opt.Callback and opt.Default ~= nil then opt.Callback(state) end
                return {Set = setState}
            end

            -- BUTTON (preto semi-transparente, borda fina, texto cinza)
            function Section:CreateButton(opt)
                opt = opt or {}
                local Row = create("Frame", {Size = UDim2.new(1, 0, 0, 26), BackgroundTransparency = 1})
                Row.Parent = Box

                local Btn = create("TextButton", {
                    Size = UDim2.new(1, 0, 1, 0),
                    BackgroundColor3 = Color3.fromRGB(0,0,0),
                    BackgroundTransparency = 0.45,
                    Text = opt.Name or "Button",
                    Font = Theme.FontBold,
                    TextSize = 11,
                    TextColor3 = Theme.SubText,
                    AutoButtonColor = false,
                }, {corner(4), stroke()})
                Btn.Parent = Row

                Btn.MouseEnter:Connect(function() tween(Btn, {TextColor3 = Theme.Text, BackgroundTransparency = 0.25}, 0.12) end)
                Btn.MouseLeave:Connect(function() tween(Btn, {TextColor3 = Theme.SubText, BackgroundTransparency = 0.45}, 0.12) end)
                Btn.MouseButton1Click:Connect(function() if opt.Callback then opt.Callback() end end)
                return Btn
            end

            function Section:CreateLabel(text)
                create("TextLabel", {
                    Text = text, Font = Theme.Font, TextSize = 12, TextColor3 = Theme.SubText,
                    BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 18),
                    TextXAlignment = Enum.TextXAlignment.Left, TextWrapped = true,
                }).Parent = Box
            end

            -- SLIDER
            function Section:CreateSlider(opt)
                opt = opt or {}
                local flag = opt.Flag or opt.Name
                local min, max = opt.Min or 0, opt.Max or 100
                local value = opt.Default or min
                Library.Flags[flag] = value

                local Row = create("Frame", {Size = UDim2.new(1, 0, 0, 34), BackgroundTransparency = 1})
                Row.Parent = Box

                create("TextLabel", {
                    Text = opt.Name or "Slider", Font = Theme.FontBold, TextSize = 12, TextColor3 = Theme.Text,
                    BackgroundTransparency = 1, Size = UDim2.new(1, -40, 0, 16),
                    TextXAlignment = Enum.TextXAlignment.Left,
                }).Parent = Row

                local ValueLabel = create("TextLabel", {
                    Text = tostring(value), Font = Theme.Font, TextSize = 11, TextColor3 = Theme.SubText,
                    BackgroundTransparency = 1, Size = UDim2.new(0, 40, 0, 16), Position = UDim2.new(1, -40, 0, 0),
                    TextXAlignment = Enum.TextXAlignment.Right,
                })
                ValueLabel.Parent = Row

                local Track = create("Frame", {
                    Size = UDim2.new(1, 0, 0, 6), Position = UDim2.new(0, 0, 1, -8),
                    BackgroundColor3 = Theme.SwitchOff,
                }, {corner(3)})
                Track.Parent = Row

                local Fill = create("Frame", {
                    Size = UDim2.new((value - min) / (max - min), 0, 1, 0),
                    BackgroundColor3 = Theme.Switch,
                }, {corner(3), vgradient(Theme.Switch, Color3.fromRGB(160,160,160), 90)})
                Fill.Parent = Track

                local function setValue(v, fireCallback)
                    v = math.clamp(v, min, max)
                    value = v
                    Library.Flags[flag] = v
                    ValueLabel.Text = tostring(math.floor(v * 100) / 100)
                    Fill.Size = UDim2.new((v - min) / (max - min), 0, 1, 0)
                    if fireCallback ~= false and opt.Callback then opt.Callback(v) end
                end

                local dragging = false
                Track.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = true end
                end)
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
                end)
                UserInputService.InputChanged:Connect(function(input)
                    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                        local rel = math.clamp((input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
                        setValue(min + (max - min) * rel)
                    end
                end)

                Library.Elements[flag] = {Set = function(v) setValue(v, false) end}
                return {Set = setValue}
            end

            -- DROPDOWN
            function Section:CreateDropdown(opt)
                opt = opt or {}
                local flag = opt.Flag or opt.Name
                local options = opt.Options or {}
                local value = opt.Default or options[1]
                Library.Flags[flag] = value

                local Row = create("Frame", {
                    Size = UDim2.new(1, 0, 0, 26), BackgroundTransparency = 1, ClipsDescendants = true, ZIndex = 2,
                })
                Row.Parent = Box

                local HeaderBtn = create("TextButton", {
                    Size = UDim2.new(1, 0, 0, 26), BackgroundTransparency = 1, Text = "", AutoButtonColor = false, ZIndex = 2,
                })
                HeaderBtn.Parent = Row

                create("TextLabel", {
                    Text = opt.Name or "Dropdown", Font = Theme.FontBold, TextSize = 12, TextColor3 = Theme.Text,
                    BackgroundTransparency = 1, Size = UDim2.new(0.5, 0, 1, 0), Position = UDim2.new(0, 4, 0, 0),
                    TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 2,
                }).Parent = HeaderBtn

                local SelectedLabel = create("TextLabel", {
                    Text = tostring(value), Font = Theme.Font, TextSize = 11, TextColor3 = Theme.SubText,
                    BackgroundTransparency = 1, Size = UDim2.new(0.5, -4, 1, 0), Position = UDim2.new(0.5, 0, 0, 0),
                    TextXAlignment = Enum.TextXAlignment.Right, ZIndex = 2,
                })
                SelectedLabel.Parent = HeaderBtn

                local List = create("Frame", {
                    Size = UDim2.new(1, 0, 0, #options * 24), Position = UDim2.new(0, 0, 0, 26), BackgroundTransparency = 1,
                }, {create("UIListLayout", {Padding = UDim.new(0, 2)})})
                List.Parent = Row

                local open = false
                local function setValue(v, fireCallback)
                    value = v
                    Library.Flags[flag] = v
                    SelectedLabel.Text = tostring(v)
                    if fireCallback ~= false and opt.Callback then opt.Callback(v) end
                end

                for _, optionName in ipairs(options) do
                    local OptBtn = create("TextButton", {
                        Size = UDim2.new(1, 0, 0, 22),
                        BackgroundColor3 = Color3.fromRGB(0,0,0), BackgroundTransparency = 0.4,
                        Text = optionName, Font = Theme.Font, TextSize = 11, TextColor3 = Theme.SubText, AutoButtonColor = false,
                    }, {corner(4)})
                    OptBtn.Parent = List
                    OptBtn.MouseButton1Click:Connect(function()
                        setValue(optionName)
                        open = false
                        tween(Row, {Size = UDim2.new(1, 0, 0, 26)}, 0.15)
                    end)
                end

                HeaderBtn.MouseButton1Click:Connect(function()
                    open = not open
                    tween(Row, {Size = open and UDim2.new(1, 0, 0, 26 + #options * 24) or UDim2.new(1, 0, 0, 26)}, 0.15)
                end)

                Library.Elements[flag] = {Set = function(v) setValue(v, false) end}
                return {Set = setValue}
            end

            -- KEYBIND
            function Section:CreateKeybind(opt)
                opt = opt or {}
                local flag = opt.Flag or opt.Name
                local key = opt.Default or Enum.KeyCode.Unknown
                Library.Flags[flag] = key.Name

                local Row = create("Frame", {Size = UDim2.new(1, 0, 0, 26), BackgroundTransparency = 1})
                Row.Parent = Box

                create("TextLabel", {
                    Text = opt.Name or "Keybind", Font = Theme.FontBold, TextSize = 12, TextColor3 = Theme.Text,
                    BackgroundTransparency = 1, Size = UDim2.new(1, -70, 1, 0), Position = UDim2.new(0, 4, 0, 0),
                    TextXAlignment = Enum.TextXAlignment.Left,
                }).Parent = Row

                local KeyBtn = create("TextButton", {
                    Size = UDim2.fromOffset(60, 20), Position = UDim2.new(1, -62, 0.5, -10),
                    BackgroundColor3 = Color3.fromRGB(0,0,0), BackgroundTransparency = 0.45,
                    Text = key.Name, Font = Theme.Font, TextSize = 10, TextColor3 = Theme.SubText, AutoButtonColor = false,
                }, {corner(4), stroke()})
                KeyBtn.Parent = Row

                local listening = false
                KeyBtn.MouseButton1Click:Connect(function() listening = true; KeyBtn.Text = "..." end)
                UserInputService.InputBegan:Connect(function(input, gpe)
                    if listening and input.UserInputType == Enum.UserInputType.Keyboard then
                        key = input.KeyCode
                        KeyBtn.Text = key.Name
                        Library.Flags[flag] = key.Name
                        listening = false
                        if opt.Callback then opt.Callback(key) end
                    elseif not gpe and input.KeyCode == key and opt.OnPress then
                        opt.OnPress()
                    end
                end)

                Library.Elements[flag] = {Set = function(v)
                    key = Enum.KeyCode[v] or Enum.KeyCode.Unknown
                    KeyBtn.Text = key.Name
                end}
                return KeyBtn
            end

            -- TEXTBOX
            function Section:CreateTextbox(opt)
                opt = opt or {}
                local flag = opt.Flag or opt.Name
                Library.Flags[flag] = opt.Default or ""

                local Row = create("Frame", {Size = UDim2.new(1, 0, 0, 26), BackgroundTransparency = 1})
                Row.Parent = Box

                local Box2 = create("Frame", {
                    Size = UDim2.new(1, 0, 1, 0), BackgroundColor3 = Color3.fromRGB(0,0,0), BackgroundTransparency = 0.45,
                }, {corner(4), stroke()})
                Box2.Parent = Row

                local Input = create("TextBox", {
                    Size = UDim2.new(1, -10, 1, 0), Position = UDim2.new(0, 5, 0, 0),
                    BackgroundTransparency = 1, Text = opt.Default or "", PlaceholderText = opt.Placeholder or "",
                    Font = Theme.Font, TextSize = 11, TextColor3 = Theme.Text, PlaceholderColor3 = Theme.SubText,
                    TextXAlignment = Enum.TextXAlignment.Left, ClearTextOnFocus = false,
                })
                Input.Parent = Box2

                Input.FocusLost:Connect(function(enterPressed)
                    Library.Flags[flag] = Input.Text
                    if opt.Callback then opt.Callback(Input.Text, enterPressed) end
                end)

                Library.Elements[flag] = {Set = function(v) Input.Text = v end}
                return Input
            end

            -- COLOR PICKER
            function Section:CreateColorPicker(opt)
                opt = opt or {}
                local flag = opt.Flag or opt.Name
                local color = opt.Default or Color3.fromRGB(255, 255, 255)
                Library.Flags[flag] = {color.R, color.G, color.B}

                local Row = create("Frame", {Size = UDim2.new(1, 0, 0, 26), BackgroundTransparency = 1, ClipsDescendants = true, ZIndex = 3})
                Row.Parent = Box

                create("TextLabel", {
                    Text = opt.Name or "Color", Font = Theme.FontBold, TextSize = 12, TextColor3 = Theme.Text,
                    BackgroundTransparency = 1, Size = UDim2.new(1, -40, 0, 26), Position = UDim2.new(0, 4, 0, 0),
                    TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 3,
                }).Parent = Row

                local Preview = create("TextButton", {
                    Size = UDim2.fromOffset(20, 20), Position = UDim2.new(1, -24, 0, 3),
                    BackgroundColor3 = color, Text = "", AutoButtonColor = false, ZIndex = 3,
                }, {corner(4), stroke()})
                Preview.Parent = Row

                local Panel = create("Frame", {
                    Size = UDim2.new(1, 0, 0, 84), Position = UDim2.new(0, 0, 0, 30),
                    BackgroundColor3 = Theme.PanelDark, ZIndex = 3,
                }, {corner(4), stroke()})
                Panel.Parent = Row

                local function makeChannel(labelText, yPos, initial, onChange)
                    local ChRow = create("Frame", {Size = UDim2.new(1, -16, 0, 22), Position = UDim2.new(0, 8, 0, yPos), BackgroundTransparency = 1, ZIndex = 3})
                    ChRow.Parent = Panel
                    create("TextLabel", {Text = labelText, Font = Theme.Font, TextSize = 10, TextColor3 = Theme.SubText, BackgroundTransparency = 1, Size = UDim2.fromOffset(14, 22), ZIndex = 3}).Parent = ChRow
                    local Track = create("Frame", {Size = UDim2.new(1, -20, 0, 4), Position = UDim2.new(0, 18, 0.5, -2), BackgroundColor3 = Theme.SwitchOff, ZIndex = 3}, {corner(2)})
                    Track.Parent = ChRow
                    local Fill = create("Frame", {Size = UDim2.new(initial, 0, 1, 0), BackgroundColor3 = Theme.Switch, ZIndex = 3}, {corner(2)})
                    Fill.Parent = Track
                    local dragging = false
                    Track.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true end end)
                    UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
                    UserInputService.InputChanged:Connect(function(input)
                        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                            local rel = math.clamp((input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
                            Fill.Size = UDim2.new(rel, 0, 1, 0)
                            onChange(rel)
                        end
                    end)
                end

                local r, g, b = color.R, color.G, color.B
                local function updateColor()
                    local newColor = Color3.new(r, g, b)
                    Preview.BackgroundColor3 = newColor
                    Library.Flags[flag] = {r, g, b}
                    if opt.Callback then opt.Callback(newColor) end
                end
                makeChannel("R", 4, r, function(v) r = v; updateColor() end)
                makeChannel("G", 28, g, function(v) g = v; updateColor() end)
                makeChannel("B", 52, b, function(v) b = v; updateColor() end)

                local open = false
                Preview.MouseButton1Click:Connect(function()
                    open = not open
                    tween(Row, {Size = open and UDim2.new(1, 0, 0, 26 + 88) or UDim2.new(1, 0, 0, 26)}, 0.15)
                end)

                Library.Elements[flag] = {Set = function(v) r, g, b = v[1], v[2], v[3]; updateColor() end}
                return {Set = function(c) r, g, b = c.R, c.G, c.B; updateColor() end}
            end

            return Section
        end

        return Tab
    end

    return Window
end

return Library
