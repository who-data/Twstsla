                    opt.OnPress()
                end
            end)

            Library.Elements[flag] = {Set = function(v)
                key = Enum.KeyCode[v] or Enum.KeyCode.Unknown
                KeyBtn.Text = key.Name
            end}

            return KeyBtn
        end

