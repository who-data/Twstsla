local Library = {}
Library.__index = Library
Library.Flags = {}          -- guarda os valores atuais { [flag] = value }
Library.Elements = {}       -- guarda referências { [flag] = {Set = function(value) end} }
Library.ConfigFolder = "UILibConfigs"

------------------------------------------------------------
-- CONFIG: SAVE / LOAD
------------------------------------------------------------
local function ensureFolder()
    if not isfolder(Library.ConfigFolder) then
        makefolder(Library.ConfigFolder)
    end
end

function Library:SaveConfig(name)
    local ok, err = pcall(function()
        ensureFolder()
        local data = HttpService:JSONEncode(Library.Flags)
        writefile(Library.ConfigFolder .. "/" .. name .. ".json", data)
    end)
    return ok, err
end

function Library:LoadConfig(name)
    local ok, err = pcall(function()
        local path = Library.ConfigFolder .. "/" .. name .. ".json"
        if not isfile(path) then error("Config não encontrada: " .. name) end
        local data = HttpService:JSONDecode(readfile(path))
        for flag, value in pairs(data) do
            Library.Flags[flag] = value
            local el = Library.Elements[flag]
            if el and el.Set then
                el.Set(value)
            end
        end
    end)
    return ok, err
end

function Library:ListConfigs()
    local list = {}
    pcall(function()
        ensureFolder()
        for _, file in ipairs(listfiles(Library.ConfigFolder)) do
            local name = file:match("([^/\\]+)%.json$")
            if name then table.insert(list, name) end
        end
    end)
    return list
end

function Library:DeleteConfig(name)
    return pcall(function()
        delfile(Library.ConfigFolder .. "/" .. name .. ".json")
    end)
end

