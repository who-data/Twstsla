    UILib - Biblioteca dez UI genérica para Roblox (executors)
    Componentes: Window, Tab, Toggle, Button, Slider, Dropdown, ColorPicker, Keybind, Textbox, Label, Section
    Config: Save/Load via writefile/readfile (JSON)
    Uso (loadstring):
        local UILib = loadstring(game:HttpGet("https://raw.githubusercontent.com/SEU_USER/SEU_REPO/main/UILib.lua"))()
]]

local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")

local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

-- usa gethui() (CoreGui protegido) quando disponível, com fallback pro PlayerGui
local function getGuiParent()
    local ok, hui = pcall(function() return gethui() end)
    if ok and hui then return hui end
    local ok2, core = pcall(function() return game:GetService("CoreGui") end)
    if ok2 and core then return core end
    return PlayerGui
end

