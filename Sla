function TabMethods:AddToggle(text, default, callback)
	local c = card(self.Page, 40, nextOrder(self))
	local state = default and true or false

	new("TextLabel", {
		Text = text,
		TextColor3 = TEXT_SECONDARY,
		Font = Enum.Font.Gotham,
		TextSize = 15,
		TextXAlignment = Enum.TextXAlignment.Left,
		BackgroundTransparency = 1,
		Size = UDim2.new(0.6, 0, 1, 0),
		Position = UDim2.new(0.05, 0, 0, 0),
	}).Parent = c

	local track = new("Frame", {
		AnchorPoint = Vector2.new(1, 0.5),
		Position = UDim2.new(0.95, 0, 0.5, 0),
		Size = UDim2.new(0, 38, 0, 18),
		BackgroundColor3 = state and ACCENT or BG_TRACK,
		BorderSizePixel = 0,
	})
	track.Parent = c
	new("UICorner", { CornerRadius = UDim.new(1, 0) }).Parent = track

	local knob = new("Frame", {
		Position = state and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7),
		Size = UDim2.new(0, 14, 0, 14),
		BackgroundColor3 = state and Color3.new(1, 1, 1) or KNOB_OFF,
		BorderSizePixel = 0,
	})
	knob.Parent = track
	new("UICorner", { CornerRadius = UDim.new(1, 0) }).Parent = knob

	local btn = new("TextButton", { Text = "", BackgroundTransparency = 1, Size = UDim2.fromScale(1, 1) })
	btn.Parent = c

	btn.MouseButton1Click:Connect(function()
		state = not state
		TweenService:Create(track, TweenInfo.new(0.2, Enum.EasingStyle.Quint), { BackgroundColor3 = state and ACCENT or BG_TRACK }):Play()
		TweenService:Create(knob, TweenInfo.new(0.2, Enum.EasingStyle.Quint), {
			Position = state and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7),
			BackgroundColor3 = state and Color3.new(1, 1, 1) or KNOB_OFF,
		}):Play()
		if callback then
			callback(state)
		end
	end)

	return c
end

function TabMethods:AddSlider(text, min, max, default, callback)
	local c = card(self.Page, 40, nextOrder(self))
	local value = math.clamp(default or min, min, max)

	new("TextLabel", {
		Text = text,
		TextColor3 = TEXT_SECONDARY,
		Font = Enum.Font.Gotham,
		TextSize = 15,
		TextXAlignment = Enum.TextXAlignment.Left,
		BackgroundTransparency = 1,
		Size = UDim2.new(0.4, -10, 1, 0),
		Position = UDim2.new(0.05, 0, 0, 0),
	}).Parent = c

	local track = new("Frame", {
		AnchorPoint = Vector2.new(1, 0.5),
		Position = UDim2.new(0.95, -48, 0.5, 0),
		Size = UDim2.new(0.45, 0, 0, 6),
		BackgroundColor3 = BG_TRACK,
		BorderSizePixel = 0,
	})
	track.Parent = c
	new("UICorner", { CornerRadius = UDim.new(1, 0) }).Parent = track

	local fillScale = (value - min) / (max - min)
	local fill = new("Frame", {
		BackgroundColor3 = ACCENT,
		BorderSizePixel = 0,
		Size = UDim2.new(fillScale, 0, 1, 0),
	})
	fill.Parent = track
	new("UICorner", { CornerRadius = UDim.new(1, 0) }).Parent = fill

	local thumb = new("Frame", {
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position = UDim2.new(fillScale, 0, 0.5, 0),
		Size = UDim2.new(0, 12, 0, 12),
		BackgroundColor3 = Color3.new(1, 1, 1),
		BorderSizePixel = 0,
	})
	thumb.Parent = track
	new("UICorner", { CornerRadius = UDim.new(1, 0) }).Parent = thumb

	local valueBox = new("TextBox", {
		AnchorPoint = Vector2.new(1, 0.5),
		Position = UDim2.new(0.95, 0, 0.5, 0),
		Size = UDim2.new(0, 40, 0, 20),
		BackgroundColor3 = Color3.fromRGB(22, 22, 32),
		BorderSizePixel = 0,
		Font = Enum.Font.GothamMedium,
		TextSize = 12,
		TextColor3 = ACCENT,
		Text = tostring(value),
		ClearTextOnFocus = false,
	})
	valueBox.Parent = c
	new("UICorner", { CornerRadius = UDim.new(0, 4) }).Parent = valueBox

	local function setValue(v)
		value = math.clamp(math.floor(v + 0.5), min, max)
		local rel = (value - min) / (max - min)
		fill.Size = UDim2.new(rel, 0, 1, 0)
		thumb.Position = UDim2.new(rel, 0, 0.5, 0)
		valueBox.Text = tostring(value)
		if callback then
			callback(value)
		end
	end

	local dragging = false
	local function setFromX(x)
		local rel = math.clamp((x - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
		setValue(min + (max - min) * rel)
	end

	track.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			setFromX(input.Position.X)
		end
	end)
	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			setFromX(input.Position.X)
		end
	end)
	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)

	valueBox.FocusLost:Connect(function()
		local n = tonumber(valueBox.Text)
		if n then
			setValue(n)
		else
			valueBox.Text = tostring(value)
		end
	end)

	return c
end

function TabMethods:AddDropdown(text, options, callback)
	local expanded = false
	local c = card(self.Page, 40, nextOrder(self))
	c.ClipsDescendants = true

	local header = new("TextButton", {
		Text = "",
		AutoButtonColor = false,
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 0, 40),
	})
	header.Parent = c

	local label = new("TextLabel", {
		Text = text .. (options[1] and (": " .. options[1]) or ""),
		TextColor3 = TEXT_SECONDARY,
		Font = Enum.Font.GothamMedium,
		TextSize = 15,
		TextXAlignment = Enum.TextXAlignment.Left,
		BackgroundTransparency = 1,
		Size = UDim2.new(0.8, 0, 1, 0),
		Position = UDim2.new(0.05, 0, 0, 0),
	})
	label.Parent = header

	local arrow = new("TextLabel", {
		Text = "\u{25BC}",
		TextColor3 = KNOB_OFF,
		Font = Enum.Font.GothamBold,
		TextSize = 10,
		BackgroundTransparency = 1,
		AnchorPoint = Vector2.new(1, 0.5),
		Position = UDim2.new(0.95, 0, 0.5, 0),
		Size = UDim2.new(0, 16, 0, 16),
	})
	arrow.Parent = header

	local list = new("Frame", {
		BackgroundTransparency = 1,
		Position = UDim2.new(0, 0, 0, 40),
		Size = UDim2.new(1, 0, 0, #options * 30),
	})
	list.Parent = c
	new("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 2) }).Parent = list
	new("UIPadding", { PaddingTop = UDim.new(0, 2) }).Parent = list

	for _, opt in ipairs(options) do
		local optBtn = new("TextButton", {
			Text = "  " .. opt,
			TextColor3 = TEXT_PRIMARY,
			Font = Enum.Font.Gotham,
			TextSize = 13,
			TextXAlignment = Enum.TextXAlignment.Left,
			BackgroundColor3 = Color3.fromRGB(26, 26, 38),
			BorderSizePixel = 0,
			AutoButtonColor = false,
			Size = UDim2.new(0.94, 0, 0, 26),
			Position = UDim2.new(0.03, 0, 0, 0),
		})
		optBtn.Parent = list
		new("UICorner", { CornerRadius = UDim.new(0, 5) }).Parent = optBtn

		optBtn.MouseEnter:Connect(function()
			TweenService:Create(optBtn, TweenInfo.new(0.1), { BackgroundColor3 = ACCENT, TextColor3 = ACCENT_DARK_TEXT }):Play()
		end)
		optBtn.MouseLeave:Connect(function()
			TweenService:Create(optBtn, TweenInfo.new(0.1), { BackgroundColor3 = Color3.fromRGB(26, 26, 38), TextColor3 = TEXT_PRIMARY }):Play()
		end)

		optBtn.MouseButton1Click:Connect(function()
			label.Text = text .. ": " .. opt
			if callback then
				callback(opt)
			end
		end)
	end

	header.MouseButton1Click:Connect(function()
		expanded = not expanded
		local targetHeight = expanded and (40 + #options * 30 + 4) or 40
		TweenService:Create(c, TweenInfo.new(0.2, Enum.EasingStyle.Quint), { Size = UDim2.new(0.88, 0, 0, targetHeight) }):Play()
		TweenService:Create(arrow, TweenInfo.new(0.2), { Rotation = expanded and 180 or 0 }):Play()
	end)

	return c
end

function TabMethods:AddKeybind(text, default, callback)
	local c = card(self.Page, 40, nextOrder(self))

	new("TextLabel", {
		Text = text,
		TextColor3 = TEXT_SECONDARY,
		Font = Enum.Font.Gotham,
		TextSize = 15,
		TextXAlignment = Enum.TextXAlignment.Left,
		BackgroundTransparency = 1,
		Size = UDim2.new(0.6, 0, 1, 0),
		Position = UDim2.new(0.05, 0, 0, 0),
	}).Parent = c

	local keyBtn = new("TextButton", {
		AnchorPoint = Vector2.new(1, 0.5),
		Position = UDim2.new(0.95, 0, 0.5, 0),
		Size = UDim2.new(0, 70, 0, 22),
		BackgroundColor3 = Color3.fromRGB(40, 40, 57),
		BorderSizePixel = 0,
		Font = Enum.Font.GothamMedium,
		TextSize = 12,
		TextColor3 = ACCENT_LIGHT,
		Text = default or "None",
		AutoButtonColor = false,
	})
	keyBtn.Parent = c
	new("UICorner", { CornerRadius = UDim.new(0, 5) }).Parent = keyBtn

	local currentKey = default or "None"
	local listening = false

	keyBtn.MouseButton1Click:Connect(function()
		if listening then
			return
		end
		listening = true
		keyBtn.Text = "..."
		local conn
		conn = UserInputService.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.Keyboard then
				currentKey = input.KeyCode.Name
				keyBtn.Text = currentKey
				listening = false
				conn:Disconnect()
				if callback then
					callback(currentKey)
				end
			end
		end)
	end)

	return c
end

function TabMethods:AddToggleSlider(text, defaultToggle, min, max, defaultSlider, callbackToggle, callbackSlider)
	local c = card(self.Page, 46, nextOrder(self))
	local state = defaultToggle and true or false
	local value = math.clamp(defaultSlider or min, min, max)

	new("TextLabel", {
		Text = text,
		TextColor3 = TEXT_SECONDARY,
		Font = Enum.Font.Gotham,
		TextSize = 14,
		TextXAlignment = Enum.TextXAlignment.Left,
		BackgroundTransparency = 1,
		Size = UDim2.new(0.35, -10, 1, 0),
		Position = UDim2.new(0.05, 0, 0, 0),
	}).Parent = c

	-- Toggle (direita)
	local track = new("Frame", {
		AnchorPoint = Vector2.new(1, 0.5),
		Position = UDim2.new(0.95, 0, 0.5, 0),
		Size = UDim2.new(0, 38, 0, 18),
		BackgroundColor3 = state and ACCENT or BG_TRACK,
		BorderSizePixel = 0,
	})
	track.Parent = c
	new("UICorner", { CornerRadius = UDim.new(1, 0) }).Parent = track

	local knob = new("Frame", {
		Position = state and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7),
		Size = UDim2.new(0, 14, 0, 14),
		BackgroundColor3 = state and Color3.new(1, 1, 1) or KNOB_OFF,
		BorderSizePixel = 0,
	})
	knob.Parent = track
	new("UICorner", { CornerRadius = UDim.new(1, 0) }).Parent = knob

	local toggleBtn = new("TextButton", {
		AnchorPoint = Vector2.new(1, 0.5),
		Position = UDim2.new(0.95, 0, 0.5, 0),
		Size = UDim2.new(0, 44, 1, 0),
		BackgroundTransparency = 1,
		Text = "",
	})
	toggleBtn.Parent = c

	toggleBtn.MouseButton1Click:Connect(function()
		state = not state
		TweenService:Create(track, TweenInfo.new(0.2, Enum.EasingStyle.Quint), { BackgroundColor3 = state and ACCENT or BG_TRACK }):Play()
		TweenService:Create(knob, TweenInfo.new(0.2, Enum.EasingStyle.Quint), {
			Position = state and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7),
			BackgroundColor3 = state and Color3.new(1, 1, 1) or KNOB_OFF,
		}):Play()
		if callbackToggle then
			callbackToggle(state)
		end
	end)

	-- Slider (esquerda do toggle)
	local sliderTrack = new("Frame", {
		AnchorPoint = Vector2.new(1, 0.5),
		Position = UDim2.new(0.95, -50, 0.5, 0),
		Size = UDim2.new(0.42, 0, 0, 6),
		BackgroundColor3 = BG_TRACK,
		BorderSizePixel = 0,
	})
	sliderTrack.Parent = c
	new("UICorner", { CornerRadius = UDim.new(1, 0) }).Parent = sliderTrack

	local sliderFillScale = (value - min) / (max - min)
	local sliderFill = new("Frame", {
		BackgroundColor3 = ACCENT,
		BorderSizePixel = 0,
		Size = UDim2.new(sliderFillScale, 0, 1, 0),
	})
	sliderFill.Parent = sliderTrack
	new("UICorner", { CornerRadius = UDim.new(1, 0) }).Parent = sliderFill

	local sliderThumb = new("Frame", {
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position = UDim2.new(sliderFillScale, 0, 0.5, 0),
		Size = UDim2.new(0, 10, 0, 10),
		BackgroundColor3 = Color3.new(1, 1, 1),
		BorderSizePixel = 0,
	})
	sliderThumb.Parent = sliderTrack
	new("UICorner", { CornerRadius = UDim.new(1, 0) }).Parent = sliderThumb

	local function setSliderValue(v)
		value = math.clamp(math.floor(v + 0.5), min, max)
		local rel = (value - min) / (max - min)
		sliderFill.Size = UDim2.new(rel, 0, 1, 0)
		sliderThumb.Position = UDim2.new(rel, 0, 0.5, 0)
		if callbackSlider then
			callbackSlider(value)
		end
	end

	local dragging = false
	sliderTrack.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			local rel = math.clamp((input.Position.X - sliderTrack.AbsolutePosition.X) / sliderTrack.AbsoluteSize.X, 0, 1)
			setSliderValue(min + (max - min) * rel)
		end
	end)
	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local rel = math.clamp((input.Position.X - sliderTrack.AbsolutePosition.X) / sliderTrack.AbsoluteSize.X, 0, 1)
			setSliderValue(min + (max - min) * rel)
		end
	end)
	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)

	return c
end

return Library
