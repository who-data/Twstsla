end

function Library:_setupDrag()
	local frame = self.Window
	local dragging, dragInput, dragStart, startPos

	self.Drag.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = frame.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)

	self.Drag.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if input == dragInput and dragging then
			local delta = input.Position - dragStart
			frame.Position = UDim2.new(
				startPos.X.Scale, startPos.X.Offset + delta.X,
				startPos.Y.Scale, startPos.Y.Offset + delta.Y
			)
		end
	end)
end

function Library:SelectTab(tab)
	if self.CurrentTab then
		self.CurrentTab.Page.Visible = false
		TweenService:Create(self.CurrentTab.Button, TweenInfo.new(0.2), { BackgroundColor3 = BG_CARD }):Play()
		TweenService:Create(self.CurrentTab.Indicator, TweenInfo.new(0.2), { BackgroundTransparency = 1 }):Play()
	end
	tab.Page.Visible = true
	TweenService:Create(tab.Button, TweenInfo.new(0.2), { BackgroundColor3 = BG_CARD_HOVER }):Play()
	TweenService:Create(tab.Indicator, TweenInfo.new(0.2), { BackgroundTransparency = 0 }):Play()
	self.CurrentTab = tab
end

function Library:CreateTab(name, icon, description)
	local index = #self.Tabs + 1

	local button = new("TextButton", {
		Name = name,
		Text = "",
		AutoButtonColor = false,
		BackgroundColor3 = BG_CARD,
		BackgroundTransparency = 0,
		BorderSizePixel = 0,
		LayoutOrder = index,
		Size = UDim2.new(0.88, 0, 0.17, 0),
	})
	button.Parent = self.TabsContainer
	new("UICorner", { CornerRadius = UDim.new(0.215, 0) }).Parent = button

	local indicator = new("Frame", {
		Name = "Indicator",
		AnchorPoint = Vector2.new(0, 0.5),
		Position = UDim2.new(0.02, 0, 0.5, 0),
		Size = UDim2.new(0, 3, 0.5, 0),
		BackgroundColor3 = ACCENT,
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
	})
	indicator.Parent = button
	new("UICorner", { CornerRadius = UDim.new(1, 0) }).Parent = indicator

	button.MouseEnter:Connect(function()
		if self.CurrentTab and self.CurrentTab.Button == button then return end
		TweenService:Create(button, TweenInfo.new(0.15), { BackgroundColor3 = BG_CARD_HOVER }):Play()
	end)
	button.MouseLeave:Connect(function()
		if self.CurrentTab and self.CurrentTab.Button == button then return end
		TweenService:Create(button, TweenInfo.new(0.15), { BackgroundColor3 = BG_CARD }):Play()
	end)

	if icon then
		new("ImageLabel", {
			Name = "Icon",
			Image = icon,
			ImageColor3 = Color3.fromRGB(234, 234, 234),
			BackgroundTransparency = 1,
			ScaleType = Enum.ScaleType.Fit,
			AnchorPoint = Vector2.new(0, 0.5),
			Position = UDim2.new(0.043, 0, 0.5, 0),
			Size = UDim2.new(0.105, 0, 0.575, 0),
		}).Parent = button
	end

	new("TextLabel", {
		Name = "Title",
		Text = name,
		TextColor3 = Color3.fromRGB(234, 234, 234),
		TextScaled = true,
		TextWrapped = true,
		TextXAlignment = Enum.TextXAlignment.Left,
		Font = Enum.Font.GothamMedium,
		BackgroundTransparency = 1,
		AnchorPoint = Vector2.new(0, 0.5),
		Position = UDim2.new(icon and 0.192 or 0.06, 0, 0.375, 0),
		Size = UDim2.new(icon and 0.764 or 0.88, 0, 0.275, 0),
	}).Parent = button

	if description then
		new("TextLabel", {
			Name = "Description",
			Text = description,
			TextColor3 = Color3.fromRGB(174, 174, 174),
			TextScaled = true,
			TextWrapped = true,
			TextXAlignment = Enum.TextXAlignment.Left,
			Font = Enum.Font.Gotham,
			BackgroundTransparency = 1,
			AnchorPoint = Vector2.new(0, 0.5),
			Position = UDim2.new(icon and 0.192 or 0.06, 0, 0.6625, 0),
			Size = UDim2.new(icon and 0.764 or 0.88, 0, 0.21, 0),
		}).Parent = button
	end

	local page = new("ScrollingFrame", {
		Name = name,
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = UDim2.fromScale(1, 1),
		Visible = false,
		ScrollBarThickness = 3,
		ScrollBarImageColor3 = ACCENT_LIGHT,
		ScrollBarImageTransparency = 0.4,
		AutomaticCanvasSize = Enum.AutomaticSize.Y,
		CanvasSize = UDim2.new(0, 0, 0, 0),
	})
	page.Parent = self.TabPages
	new("UIListLayout", {
		Padding = UDim.new(0, 8),
		HorizontalAlignment = Enum.HorizontalAlignment.Center,
		SortOrder = Enum.SortOrder.LayoutOrder,
	}).Parent = page
	new("UIPadding", { PaddingTop = UDim.new(0, 10), PaddingBottom = UDim.new(0, 10) }).Parent = page

	local tab = setmetatable({ Button = button, Page = page, Library = self, _order = 0, Indicator = indicator }, TabMethods)

	button.MouseButton1Click:Connect(function()
		self:SelectTab(tab)
	end)

	table.insert(self.Tabs, tab)
	if #self.Tabs == 1 then
		self:SelectTab(tab)
	end

	return tab
end

