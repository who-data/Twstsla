--[[
	CrystalUILib
	Biblioteca ddddxe UI gerada a partir do design "Crystal" (Window/Main/Tabs/TabPages).
	Componentes agora usam o mesmo estilo visual/animações da NovaUI (acento violeta,
	toggles deslizantes, slider com campo editável, dropdown animado).

	Uso básico:

		local Lib = loadstring(readfile("CrystalUILib.lua"))() -- ou require(modulo)
		local Window = Lib.new("Crystal")

		local Home = Window:CreateTab("Home", "rbxassetid://73551258618338", "View your and server's information")
		Home:AddSection("Geral")
		Home:AddLabel("Bem-vindo")
		Home:AddText("Um texto informativo menor, sem interação.")
		Home:AddButton("Rejoin", function() print("rejoin") end)
		Home:AddToggle("Auto Farm", false, function(state) print(state) end)
		Home:AddSlider("Velocidade", 0, 100, 50, function(v) print(v) end)
		Home:AddDropdown("Modo", {"Passivo","Agressivo"}, function(opt) print(opt) end)
		Home:AddKeybind("Tecla", "None", function(key) print(key) end)
		Home:AddToggleSlider("Auto Aim", false, 0, 100, 50, function(state) print(state) end, function(v) print(v) end)
]]

local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")

local Library = {}
Library.__index = Library

local TabMethods = {}
TabMethods.__index = TabMethods

-- ===== helpers =====

local function new(class, props, children)
	local inst = Instance.new(class)
	for k, v in pairs(props or {}) do
		inst[k] = v
	end
	for _, child in ipairs(children or {}) do
		child.Parent = inst
	end
	return inst
end

local function applyStrokeGradient(target, c1, c2)
	local stroke = new("UIStroke", { Color = Color3.new(1, 1, 1), ApplyStrokeMode = Enum.ApplyStrokeMode.Border })
	stroke.Parent = target
	new("UIGradient", {
		Color = ColorSequence.new(c1, c2),
		Rotation = -90,
		Transparency = NumberSequence.new(0.1),
	}).Parent = stroke
	return stroke
end

local ACCENT = Color3.fromRGB(168, 130, 255)
local ACCENT_LIGHT = Color3.fromRGB(200, 170, 255)
local ACCENT_DARK_TEXT = Color3.fromRGB(28, 20, 48)
local BG_CARD = Color3.fromRGB(34, 34, 48)
local BG_CARD_HOVER = Color3.fromRGB(40, 40, 58)
local BG_TRACK = Color3.fromRGB(46, 46, 66)
local TEXT_PRIMARY = Color3.fromRGB(228, 228, 242)
local TEXT_SECONDARY = Color3.fromRGB(190, 190, 215)
local TEXT_MUTED = Color3.fromRGB(150, 148, 175)
local KNOB_OFF = Color3.fromRGB(110, 108, 140)

local function card(parent, height, order)
	local c = new("Frame", {
		BackgroundColor3 = BG_CARD,
		BackgroundTransparency = 0,
		BorderSizePixel = 0,
		Size = UDim2.new(0.88, 0, 0, height or 50),
		LayoutOrder = order or 0,
	})
	new("UICorner", { CornerRadius = UDim.new(0, 8) }).Parent = c
	return c
end

