        end

        ------------------------------------------------------------
        -- COLOR PICKER (simples: RGB sliders)
        ------------------------------------------------------------
        function Tab:CreateColorPicker(opt)
            opt = opt or {}
            local flag = opt.Flag or opt.Name
            local color = opt.Default or Color3.fromRGB(255, 255, 255)
            Library.Flags[flag] = {color.R, color.G, color.B}

            local Holder = create("Frame", {
                Size = UDim2.new(1, 0, 0, 34),
                BackgroundColor3 = Theme.Panel,
            }, {corner(6), stroke()})
            Holder.Parent = TabPage

            create("TextLabel", {
                Text = opt.Name or "Color",
                Font = Theme.Font,
                TextSize = 13,
                TextColor3 = Theme.Text,
                BackgroundTransparency = 1,
                Size = UDim2.new(1, -50, 1, 0),
                Position = UDim2.new(0, 12, 0, 0),
                TextXAlignment = Enum.TextXAlignment.Left,
            }).Parent = Holder

            local Preview = create("TextButton", {
                Size = UDim2.fromOffset(24, 24),
                Position = UDim2.new(1, -36, 0.5, 0),
                AnchorPoint = Vector2.new(0, 0.5),
                BackgroundColor3 = color,
                Text = "",
                AutoButtonColor = false,
            }, {corner(5), stroke()})
            Preview.Parent = Holder

            local panelOpen = false
            local Panel = create("Frame", {
                Size = UDim2.new(1, 0, 0, 90),
                Position = UDim2.new(0, 0, 1, 2),
                BackgroundColor3 = Theme.PanelLight,
                Visible = false,
                ZIndex = 5,
            }, {corner(6), stroke()})
            Panel.Parent = Holder

            local function makeChannel(labelText, yPos, initial, onChange)
                local Row = create("Frame", {Size = UDim2.new(1, -16, 0, 22), Position = UDim2.new(0, 8, 0, yPos), BackgroundTransparency = 1})
                Row.Parent = Panel
                create("TextLabel", {Text = labelText, Font = Theme.Font, TextSize = 11, TextColor3 = Theme.SubText, BackgroundTransparency = 1, Size = UDim2.fromOffset(14, 22)}).Parent = Row
                local Track = create("Frame", {Size = UDim2.new(1, -20, 0, 4), Position = UDim2.new(0, 18, 0.5, 0), AnchorPoint = Vector2.new(0, 0.5), BackgroundColor3 = Theme.Panel}, {corner(2)})
                Track.Parent = Row
                local Fill = create("Frame", {Size = UDim2.new(initial, 0, 1, 0), BackgroundColor3 = Theme.Accent}, {corner(2)})
                Fill.Parent = Track
                local dragging = false
                Track.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true end
                end)
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
                end)
                UserInputService.InputChanged:Connect(function(input)
                    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                        local rel = math.clamp((input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
                        Fill.Size = UDim2.new(rel, 0, 1, 0)
                        onChange(rel)
                    end
                end)
            end

            local r, g, b = color.R, color.G, color.B
            local function updateColor()
                local newColor = Color3.new(r, g, b)
                Preview.BackgroundColor3 = newColor
                Library.Flags[flag] = {r, g, b}
                if opt.Callback then opt.Callback(newColor) end
            end

            makeChannel("R", 4, r, function(v) r = v; updateColor() end)
            makeChannel("G", 30, g, function(v) g = v; updateColor() end)
            makeChannel("B", 56, b, function(v) b = v; updateColor() end)

            Preview.MouseButton1Click:Connect(function()
                panelOpen = not panelOpen
                Panel.Visible = panelOpen
            end)

            Library.Elements[flag] = {Set = function(v)
                r, g, b = v[1], v[2], v[3]
                updateColor()
            end}

            return {Set = function(c) r, g, b = c.R, c.G, c.B; updateColor() end}
        end

        return Tab
    end

    return Window
end

return Library
