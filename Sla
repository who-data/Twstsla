--[[
    UI LIBRARY
    Baseada no estilo visual do arquivo "ui.lua" enviado (cores, corner radius,
    UIStroke com gradient, fonte Jura, cards com transparência 0.5 etc).

    Como usar (exemplo no final do arquivo, dentro do bloco comentado).

    Estrutura:
        Library.new(config)              -> Window
        Window:CreateTab(nome, icon)     -> Tab
        Tab:CreateSection(nome)          -> Section
        Section:AddButton(texto, callback)
        Section:AddToggle(texto, default, callback)
        Section:AddSlider(texto, min, max, default, callback)
        Section:AddDropdown(texto, opcoes, default, callback)
        Section:AddInput(texto, placeholder, callback)
        Section:AddLabel(texto)
]]

local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")

-- ============================================================
-- TEMA (extraído do dump: cor de fundo 15,23,42 / stroke 1.5 /
-- corner 5-8 / fonte Jura / accent verde 0,200,0)
-- ============================================================
local Theme = {
    Background      = Color3.fromRGB(15, 23, 42),
    BackgroundAlt   = Color3.fromRGB(20, 20, 20),
    Stroke          = Color3.fromRGB(27, 42, 53),
    Text            = Color3.fromRGB(255, 255, 255),
    SubText         = Color3.fromRGB(180, 180, 185),
    Accent          = Color3.fromRGB(0, 200, 0),
    Font            = Enum.Font.Jura,
    CornerBig       = UDim.new(0, 8),
    CornerSmall     = UDim.new(0, 5),
    CardTransparency = 0.5,
}

local function tween(obj, props, time, style, dir)
    local t = TweenService:Create(obj, TweenInfo.new(time or 0.2, style or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out), props)
    t:Play()
    return t
end

local function make(class, props, parent)
    local inst = Instance.new(class)
    for prop, value in pairs(props) do
        inst[prop] = value
    end
    if parent then
        inst.Parent = parent
    end
    return inst
end

local function addCorner(parent, radius)
    return make("UICorner", { CornerRadius = radius or Theme.CornerSmall }, parent)
end

local function addStroke(parent, thickness, color)
    local stroke = make("UIStroke", {
        Thickness = thickness or 1.5,
        Color = color or Theme.Stroke,
        Transparency = 0,
        ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
        LineJoinMode = Enum.LineJoinMode.Round,
    }, parent)
    make("UIGradient", { Rotation = 0, Parent = stroke })
    return stroke
end

local function makeDraggable(handle, target)
    local dragging, dragStart, startPos
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = target.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    handle.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            target.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

-- ============================================================
-- LIBRARY
-- ============================================================
local Library = {}
Library.__index = Library

function Library.new(config)
    config = config or {}
    local self = setmetatable({}, Library)

    self.Title = config.Title or "Window"
    self.SubTitle = config.SubTitle or ""
    self.Tabs = {}

    -- ScreenGui raiz
    self.ScreenGui = make("ScreenGui", {
        Name = config.Name or "UILibrary",
        ResetOnSpawn = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
    }, CoreGui)

    -- Janela principal (CanvasGroup, igual ao "Oi" do dump)
    self.Main = make("CanvasGroup", {
        Name = "Main",
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(0.5, 0, 0.5, 0),
        Size = config.Size or UDim2.new(0, 560, 0, 380),
        BackgroundColor3 = Theme.Background,
        BackgroundTransparency = Theme.CardTransparency,
        BorderSizePixel = 0,
        ClipsDescendants = true,
    }, self.ScreenGui)
    addCorner(self.Main, Theme.CornerBig)
    addStroke(self.Main, 1.5)

    -- Barra de título
    self.TitleBar = make("Frame", {
        Name = "TitleBar",
        Size = UDim2.new(1, 0, 0, 44),
        BackgroundTransparency = 1,
    }, self.Main)

    make("TextLabel", {
        Name = "Title",
        Position = UDim2.new(0, 16, 0, 0),
        Size = UDim2.new(1, -100, 1, 0),
        BackgroundTransparency = 1,
        Font = Theme.Font,
        Text = self.Title,
        TextColor3 = Theme.Text,
        TextSize = 18,
        TextXAlignment = Enum.TextXAlignment.Left,
    }, self.TitleBar)

    if self.SubTitle ~= "" then
        make("TextLabel", {
            Name = "SubTitle",
            Position = UDim2.new(0, 16, 0, 22),
            Size = UDim2.new(1, -100, 0, 16),
            BackgroundTransparency = 1,
            Font = Theme.Font,
            Text = self.SubTitle,
            TextColor3 = Theme.SubText,
            TextSize = 12,
            TextXAlignment = Enum.TextXAlignment.Left,
        }, self.TitleBar)
    end

    -- Botão de fechar
    local closeBtn = make("TextButton", {
        Name = "Close",
        AnchorPoint = Vector2.new(1, 0),
        Position = UDim2.new(1, -12, 0, 10),
        Size = UDim2.new(0, 26, 0, 26),
        BackgroundColor3 = Theme.BackgroundAlt,
        BackgroundTransparency = 0.5,
        Font = Theme.Font,
        Text = "X",
        TextColor3 = Theme.Text,
        TextSize = 14,
        AutoButtonColor = false,
    }, self.TitleBar)
    addCorner(closeBtn)
    closeBtn.MouseButton1Click:Connect(function()
        self.ScreenGui:Destroy()
    end)

    makeDraggable(self.TitleBar, self.Main)

    -- Coluna de abas (esquerda) + conteúdo (direita)
    self.TabHolder = make("Frame", {
        Name = "Tabs",
        Position = UDim2.new(0, 12, 0, 54),
        Size = UDim2.new(0, 120, 1, -66),
        BackgroundTransparency = 1,
    }, self.Main)
    make("UIListLayout", {
        Padding = UDim.new(0, 6),
        SortOrder = Enum.SortOrder.LayoutOrder,
    }, self.TabHolder)

    self.ContentHolder = make("Frame", {
        Name = "Content",
        Position = UDim2.new(0, 144, 0, 54),
        Size = UDim2.new(1, -156, 1, -66),
        BackgroundTransparency = 1,
    }, self.Main)

    return self
end

-- ============================================================
-- TAB
-- ============================================================
function Library:CreateTab(name, icon)
    local tabButton = make("TextButton", {
        Name = name,
        Size = UDim2.new(1, 0, 0, 34),
        BackgroundColor3 = Theme.BackgroundAlt,
        BackgroundTransparency = 0.6,
        Font = Theme.Font,
        Text = "   " .. name,
        TextColor3 = Theme.SubText,
        TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Left,
        AutoButtonColor = false,
    }, self.TabHolder)
    addCorner(tabButton)

    local page = make("ScrollingFrame", {
        Name = name .. "Page",
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 3,
        ScrollBarImageColor3 = Theme.Accent,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        Visible = false,
    }, self.ContentHolder)
    make("UIListLayout", {
        Padding = UDim.new(0, 8),
        SortOrder = Enum.SortOrder.LayoutOrder,
    }, page)
    make("UIPadding", {
        PaddingRight = UDim.new(0, 6),
    }, page)

    local tab = { Button = tabButton, Page = page, Sections = {} }

    tabButton.MouseButton1Click:Connect(function()
        for _, t in pairs(self.Tabs) do
            t.Page.Visible = false
            tween(t.Button, { BackgroundTransparency = 0.6, TextColor3 = Theme.SubText }, 0.15)
        end
        page.Visible = true
        tween(tabButton, { BackgroundTransparency = 0.1, TextColor3 = Theme.Text }, 0.15)
    end)

    table.insert(self.Tabs, tab)
    if #self.Tabs == 1 then
        page.Visible = true
        tabButton.BackgroundTransparency = 0.1
        tabButton.TextColor3 = Theme.Text
    end

    -- ==========================================================
    -- SECTION
    -- ==========================================================
    function tab:CreateSection(sectionName)
        local sectionFrame = make("Frame", {
            Name = sectionName,
            Size = UDim2.new(1, 0, 0, 0),
            AutomaticSize = Enum.AutomaticSize.Y,
            BackgroundColor3 = Theme.BackgroundAlt,
            BackgroundTransparency = 0.6,
        }, page)
        addCorner(sectionFrame)
        addStroke(sectionFrame, 1)

        make("UIPadding", {
            PaddingLeft = UDim.new(0, 10),
            PaddingRight = UDim.new(0, 10),
            PaddingTop = UDim.new(0, 10),
            PaddingBottom = UDim.new(0, 10),
        }, sectionFrame)

        make("TextLabel", {
            Name = "SectionTitle",
            Size = UDim2.new(1, 0, 0, 20),
            BackgroundTransparency = 1,
            Font = Theme.Font,
            Text = sectionName,
            TextColor3 = Theme.Text,
            TextSize = 15,
            TextXAlignment = Enum.TextXAlignment.Left,
        }, sectionFrame)

        local list = make("Frame", {
            Name = "List",
            Position = UDim2.new(0, 0, 0, 26),
            Size = UDim2.new(1, 0, 0, 0),
            AutomaticSize = Enum.AutomaticSize.Y,
            BackgroundTransparency = 1,
        }, sectionFrame)
        make("UIListLayout", {
            Padding = UDim.new(0, 6),
            SortOrder = Enum.SortOrder.LayoutOrder,
        }, list)

        local section = {}

        -- ---------------- BUTTON ----------------
        function section:AddButton(text, callback)
            callback = callback or function() end
            local btn = make("TextButton", {
                Size = UDim2.new(1, 0, 0, 32),
                BackgroundColor3 = Theme.Background,
                BackgroundTransparency = 0.3,
                Font = Theme.Font,
                Text = text,
                TextColor3 = Theme.Text,
                TextSize = 14,
                AutoButtonColor = false,
            }, list)
            addCorner(btn)

            btn.MouseEnter:Connect(function() tween(btn, { BackgroundTransparency = 0.0 }, 0.15) end)
            btn.MouseLeave:Connect(function() tween(btn, { BackgroundTransparency = 0.3 }, 0.15) end)
            btn.MouseButton1Click:Connect(function()
                tween(btn, { BackgroundColor3 = Theme.Accent }, 0.1)
                task.wait(0.1)
                tween(btn, { BackgroundColor3 = Theme.Background }, 0.2)
                callback()
            end)
            return btn
        end

        -- ---------------- TOGGLE ----------------
        function section:AddToggle(text, default, callback)
            callback = callback or function() end
            local state = default or false

            local holder = make("Frame", {
                Size = UDim2.new(1, 0, 0, 32),
                BackgroundTransparency = 1,
            }, list)

            make("TextLabel", {
                Size = UDim2.new(1, -50, 1, 0),
                BackgroundTransparency = 1,
                Font = Theme.Font,
                Text = text,
                TextColor3 = Theme.Text,
                TextSize = 14,
                TextXAlignment = Enum.TextXAlignment.Left,
            }, holder)

            local switch = make("TextButton", {
                AnchorPoint = Vector2.new(1, 0.5),
                Position = UDim2.new(1, 0, 0.5, 0),
                Size = UDim2.new(0, 40, 0, 22),
                BackgroundColor3 = state and Theme.Accent or Theme.Background,
                BackgroundTransparency = 0.2,
                Text = "",
                AutoButtonColor = false,
            }, holder)
            addCorner(switch, UDim.new(1, 0))

            local knob = make("Frame", {
                AnchorPoint = Vector2.new(0, 0.5),
                Position = state and UDim2.new(1, -20, 0.5, 0) or UDim2.new(0, 2, 0.5, 0),
                Size = UDim2.new(0, 18, 0, 18),
                BackgroundColor3 = Theme.Text,
            }, switch)
            addCorner(knob, UDim.new(1, 0))

            switch.MouseButton1Click:Connect(function()
                state = not state
                tween(switch, { BackgroundColor3 = state and Theme.Accent or Theme.Background }, 0.15)
                tween(knob, { Position = state and UDim2.new(1, -20, 0.5, 0) or UDim2.new(0, 2, 0.5, 0) }, 0.15)
                callback(state)
            end)

            return { Set = function(_, v) state = v; switch.BackgroundColor3 = v and Theme.Accent or Theme.Background; knob.Position = v and UDim2.new(1, -20, 0.5, 0) or UDim2.new(0, 2, 0.5, 0) end }
        end

        -- ---------------- SLIDER ----------------
        function section:AddSlider(text, min, max, default, callback)
            callback = callback or function() end
            min, max = min or 0, max or 100
            local value = math.clamp(default or min, min, max)

            local holder = make("Frame", {
                Size = UDim2.new(1, 0, 0, 40),
                BackgroundTransparency = 1,
            }, list)

            make("TextLabel", {
                Size = UDim2.new(1, -50, 0, 18),
                BackgroundTransparency = 1,
                Font = Theme.Font,
                Text = text,
                TextColor3 = Theme.Text,
                TextSize = 14,
                TextXAlignment = Enum.TextXAlignment.Left,
            }, holder)

            local valueLabel = make("TextLabel", {
                AnchorPoint = Vector2.new(1, 0),
                Position = UDim2.new(1, 0, 0, 0),
                Size = UDim2.new(0, 50, 0, 18),
                BackgroundTransparency = 1,
                Font = Theme.Font,
                Text = tostring(value),
                TextColor3 = Theme.Accent,
                TextSize = 14,
                TextXAlignment = Enum.TextXAlignment.Right,
            }, holder)

            local bar = make("Frame", {
                Position = UDim2.new(0, 0, 0, 24),
                Size = UDim2.new(1, 0, 0, 10),
                BackgroundColor3 = Theme.Background,
                BackgroundTransparency = 0.2,
            }, holder)
            addCorner(bar)

            local fill = make("Frame", {
                Size = UDim2.new((value - min) / (max - min), 0, 1, 0),
                BackgroundColor3 = Theme.Accent,
            }, bar)
            addCorner(fill)

            local dragging = false
            local function update(input)
                local rel = math.clamp((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
                value = math.floor(min + (max - min) * rel)
                fill.Size = UDim2.new(rel, 0, 1, 0)
                valueLabel.Text = tostring(value)
                callback(value)
            end

            bar.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = true
                    update(input)
                end
            end)
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = false
                end
            end)
            UserInputService.InputChanged:Connect(function(input)
                if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                    update(input)
                end
            end)

            return { Set = function(_, v)
                v = math.clamp(v, min, max)
                value = v
                local rel = (v - min) / (max - min)
                fill.Size = UDim2.new(rel, 0, 1, 0)
                valueLabel.Text = tostring(v)
            end }
        end

        -- ---------------- DROPDOWN ----------------
        function section:AddDropdown(text, options, default, callback)
            callback = callback or function() end
            options = options or {}
            local selected = default or options[1] or "..."
            local open = false

            local holder = make("Frame", {
                Size = UDim2.new(1, 0, 0, 32),
                BackgroundTransparency = 1,
                ClipsDescendants = false,
                ZIndex = 5,
            }, list)

            local main = make("TextButton", {
                Size = UDim2.new(1, 0, 0, 32),
                BackgroundColor3 = Theme.Background,
                BackgroundTransparency = 0.3,
                Font = Theme.Font,
                Text = "",
                AutoButtonColor = false,
                ZIndex = 5,
            }, holder)
            addCorner(main)

            make("TextLabel", {
                Position = UDim2.new(0, 10, 0, 0),
                Size = UDim2.new(1, -30, 1, 0),
                BackgroundTransparency = 1,
                Font = Theme.Font,
                Text = text,
                TextColor3 = Theme.SubText,
                TextSize = 12,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 5,
            }, main)

            local valueLabel = make("TextLabel", {
                AnchorPoint = Vector2.new(1, 0.5),
                Position = UDim2.new(1, -10, 0.5, 0),
                Size = UDim2.new(0, 100, 1, 0),
                BackgroundTransparency = 1,
                Font = Theme.Font,
                Text = tostring(selected),
                TextColor3 = Theme.Text,
                TextSize = 14,
                TextXAlignment = Enum.TextXAlignment.Right,
                ZIndex = 5,
            }, main)

            local list2 = make("Frame", {
                Position = UDim2.new(0, 0, 0, 36),
                Size = UDim2.new(1, 0, 0, 0),
                AutomaticSize = Enum.AutomaticSize.Y,
                BackgroundColor3 = Theme.Background,
                BackgroundTransparency = 0.1,
                Visible = false,
                ZIndex = 6,
            }, holder)
            addCorner(list2)
            make("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder }, list2)
            make("UIPadding", { PaddingTop = UDim.new(0, 4), PaddingBottom = UDim.new(0, 4) }, list2)

            for _, opt in ipairs(options) do
                local optBtn = make("TextButton", {
                    Size = UDim2.new(1, 0, 0, 26),
                    BackgroundTransparency = 1,
                    Font = Theme.Font,
                    Text = tostring(opt),
                    TextColor3 = Theme.SubText,
                    TextSize = 13,
                    ZIndex = 6,
                }, list2)
                optBtn.MouseEnter:Connect(function() optBtn.TextColor3 = Theme.Text end)
                optBtn.MouseLeave:Connect(function() optBtn.TextColor3 = Theme.SubText end)
                optBtn.MouseButton1Click:Connect(function()
                    selected = opt
                    valueLabel.Text = tostring(opt)
                    open = false
                    list2.Visible = false
                    callback(opt)
                end)
            end

            main.MouseButton1Click:Connect(function()
                open = not open
                list2.Visible = open
            end)

            return { Set = function(_, v) selected = v; valueLabel.Text = tostring(v) end }
        end

        -- ---------------- INPUT (TEXTBOX) ----------------
        function section:AddInput(text, placeholder, callback)
            callback = callback or function() end
            local holder = make("Frame", {
                Size = UDim2.new(1, 0, 0, 32),
                BackgroundTransparency = 1,
            }, list)

            make("TextLabel", {
                Size = UDim2.new(0.4, 0, 1, 0),
                BackgroundTransparency = 1,
                Font = Theme.Font,
                Text = text,
                TextColor3 = Theme.Text,
                TextSize = 14,
                TextXAlignment = Enum.TextXAlignment.Left,
            }, holder)

            local box = make("TextBox", {
                AnchorPoint = Vector2.new(1, 0),
                Position = UDim2.new(1, 0, 0, 0),
                Size = UDim2.new(0.55, 0, 1, 0),
                BackgroundColor3 = Theme.Background,
                BackgroundTransparency = 0.3,
                Font = Theme.Font,
                PlaceholderText = placeholder or "",
                Text = "",
                TextColor3 = Theme.Text,
                PlaceholderColor3 = Theme.SubText,
                TextSize = 13,
                ClearTextOnFocus = false,
            }, holder)
            addCorner(box)
            make("UIPadding", { PaddingLeft = UDim.new(0, 8) }, box)

            box.FocusLost:Connect(function(enterPressed)
                callback(box.Text, enterPressed)
            end)

            return box
        end

        -- ---------------- LABEL ----------------
        function section:AddLabel(text)
            local lbl = make("TextLabel", {
                Size = UDim2.new(1, 0, 0, 18),
                BackgroundTransparency = 1,
                Font = Theme.Font,
                Text = text,
                TextColor3 = Theme.SubText,
                TextSize = 13,
                TextXAlignment = Enum.TextXAlignment.Left,
                TextWrapped = true,
            }, list)
            return lbl
        end

        table.insert(tab.Sections, section)
        return section
    end

    return tab
end

return Library

