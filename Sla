function Library:CreateTab(name)
    local tabButton = make("TextButton", {
        Name = name,
        Size = UDim2.new(1, 0, 0, 34),
        BackgroundColor3 = Theme.BackgroundAlt,
        BackgroundTransparency = 0.6,
        Font = Theme.Font,
        Text = "   " .. name,
        TextColor3 = Theme.SubText,
        TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Left,
        AutoButtonColor = false,
    }, self.TabHolder)
    addCorner(tabButton)

    local page = make("ScrollingFrame", {
        Name = name .. "Page",
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 3,
        ScrollBarImageColor3 = Theme.Accent,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        Visible = false,
    }, self.ContentHolder)
    make("UIListLayout", {
        Padding = UDim.new(0, 8),
        SortOrder = Enum.SortOrder.LayoutOrder,
    }, page)
    make("UIPadding", { PaddingRight = UDim.new(0, 6) }, page)

    local tab = { Button = tabButton, Page = page, Sections = {} }

    tabButton.MouseButton1Click:Connect(function()
        for _, t in pairs(self.Tabs) do
            t.Page.Visible = false
            tween(t.Button, { BackgroundTransparency = 0.6, TextColor3 = Theme.SubText }, 0.15)
        end
        page.Visible = true
        tween(tabButton, { BackgroundTransparency = 0.1, TextColor3 = Theme.Text }, 0.15)
    end)

    table.insert(self.Tabs, tab)
    if #self.Tabs == 1 then
        page.Visible = true
        tabButton.BackgroundTransparency = 0.1
        tabButton.TextColor3 = Theme.Text
    end

    -- ==========================================================
    -- SECTION
    -- ==========================================================
    function tab:CreateSection(sectionName)
        local sectionFrame = make("Frame", {
            Name = sectionName,
            Size = UDim2.new(1, 0, 0, 0),
            AutomaticSize = Enum.AutomaticSize.Y,
            BackgroundColor3 = Theme.BackgroundAlt,
            BackgroundTransparency = 0.6,
        }, page)
        addCorner(sectionFrame)
        addStroke(sectionFrame, 1)

        make("UIPadding", {
            PaddingLeft = UDim.new(0, 10), PaddingRight = UDim.new(0, 10),
            PaddingTop = UDim.new(0, 10), PaddingBottom = UDim.new(0, 10),
        }, sectionFrame)

        make("TextLabel", {
            Name = "SectionTitle",
            Size = UDim2.new(1, 0, 0, 20),
            BackgroundTransparency = 1,
            Font = Theme.Font,
            Text = sectionName,
            TextColor3 = Theme.Text,
            TextSize = 15,
            TextXAlignment = Enum.TextXAlignment.Left,
        }, sectionFrame)

        local list = make("Frame", {
            Name = "List",
            Position = UDim2.new(0, 0, 0, 26),
            Size = UDim2.new(1, 0, 0, 0),
            AutomaticSize = Enum.AutomaticSize.Y,
            BackgroundTransparency = 1,
        }, sectionFrame)
        make("UIListLayout", {
            Padding = UDim.new(0, 6),
            SortOrder = Enum.SortOrder.LayoutOrder,
        }, list)

        local section = {}

        -- ---------------- BUTTON ----------------
        function section:AddButton(text, callback)
            callback = callback or function() end
            local btn = make("TextButton", {
                Size = UDim2.new(1, 0, 0, 32),
                BackgroundColor3 = Theme.Background,
                BackgroundTransparency = 0.3,
                Font = Theme.Font,
                Text = text,
                TextColor3 = Theme.Text,
                TextSize = 14,
                AutoButtonColor = false,
            }, list)
            addCorner(btn)

            btn.MouseEnter:Connect(function() tween(btn, { BackgroundTransparency = 0.0 }, 0.15) end)
            btn.MouseLeave:Connect(function() tween(btn, { BackgroundTransparency = 0.3 }, 0.15) end)
            btn.MouseButton1Click:Connect(function()
                tween(btn, { BackgroundColor3 = Theme.Accent }, 0.1)
                task.wait(0.1)
                tween(btn, { BackgroundColor3 = Theme.Background }, 0.2)
                callback()
            end)
            return btn
        end

        -- ---------------- TOGGLE ----------------
        function section:AddToggle(text, default, callback)
            callback = callback or function() end
            local state = default or false

            local holder = make("Frame", { Size = UDim2.new(1, 0, 0, 32), BackgroundTransparency = 1 }, list)

            make("TextLabel", {
                Size = UDim2.new(1, -50, 1, 0),
                BackgroundTransparency = 1,
                Font = Theme.Font,
                Text = text,
                TextColor3 = Theme.Text,
                TextSize = 14,
                TextXAlignment = Enum.TextXAlignment.Left,
            }, holder)

            local switch = make("TextButton", {
                AnchorPoint = Vector2.new(1, 0.5),
                Position = UDim2.new(1, 0, 0.5, 0),
                Size = UDim2.new(0, 40, 0, 22),
                BackgroundColor3 = state and Theme.Accent or Theme.Background,
                BackgroundTransparency = 0.2,
                Text = "",
                AutoButtonColor = false,
            }, holder)
            addCorner(switch, UDim.new(1, 0))

            local knob = make("Frame", {
                AnchorPoint = Vector2.new(0, 0.5),
                Position = state and UDim2.new(1, -20, 0.5, 0) or UDim2.new(0, 2, 0.5, 0),
                Size = UDim2.new(0, 18, 0, 18),
                BackgroundColor3 = Theme.Text,
            }, switch)
            addCorner(knob, UDim.new(1, 0))

            switch.MouseButton1Click:Connect(function()
                state = not state
                tween(switch, { BackgroundColor3 = state and Theme.Accent or Theme.Background }, 0.15)
                tween(knob, { Position = state and UDim2.new(1, -20, 0.5, 0) or UDim2.new(0, 2, 0.5, 0) }, 0.15)
                callback(state)
            end)

            return {
                Set = function(_, v)
                    state = v
                    switch.BackgroundColor3 = v and Theme.Accent or Theme.Background
                    knob.Position = v and UDim2.new(1, -20, 0.5, 0) or UDim2.new(0, 2, 0.5, 0)
                end,
                Get = function() return state end,
            }
        end

        -- ---------------- CHECKBOX ----------------
        function section:AddCheckbox(text, default, callback)
            callback = callback or function() end
            local state = default or false

            local holder = make("Frame", { Size = UDim2.new(1, 0, 0, 26), BackgroundTransparency = 1 }, list)

            local box = make("TextButton", {
                AnchorPoint = Vector2.new(1, 0.5),
                Position = UDim2.new(1, 0, 0.5, 0),
                Size = UDim2.new(0, 20, 0, 20),
                BackgroundColor3 = Theme.Background,
                BackgroundTransparency = 0.2,
                Text = "",
                AutoButtonColor = false,
            }, holder)
            addCorner(box, UDim.new(0, 4))
            addStroke(box, 1)

            local check = make("TextLabel", {
                Size = UDim2.new(1, 0, 1, 0),
                BackgroundTransparency = 1,
                Font = Theme.Font,
                Text = "✓",
                TextColor3 = Theme.Accent,
                TextSize = 16,
                TextTransparency = state and 0 or 1,
            }, box)

            make("TextLabel", {
                Size = UDim2.new(1, -34, 1, 0),
                BackgroundTransparency = 1,
                Font = Theme.Font,
                Text = text,
                TextColor3 = Theme.Text,
                TextSize = 14,
                TextXAlignment = Enum.TextXAlignment.Left,
            }, holder)

            box.MouseButton1Click:Connect(function()
                state = not state
                tween(check, { TextTransparency = state and 0 or 1 }, 0.12)
                callback(state)
            end)

            return {
                Set = function(_, v) state = v; check.TextTransparency = v and 0 or 1 end,
                Get = function() return state end,
            }
        end

        -- ---------------- SLIDER ----------------
        function section:AddSlider(text, min, max, default, callback)
            callback = callback or function() end
            min, max = min or 0, max or 100
            local value = math.clamp(default or min, min, max)

            local holder = make("Frame", { Size = UDim2.new(1, 0, 0, 40), BackgroundTransparency = 1 }, list)

            make("TextLabel", {
                Size = UDim2.new(1, -50, 0, 18),
                BackgroundTransparency = 1,
                Font = Theme.Font,
                Text = text,
                TextColor3 = Theme.Text,
                TextSize = 14,
                TextXAlignment = Enum.TextXAlignment.Left,
            }, holder)

            local valueLabel = make("TextLabel", {
                AnchorPoint = Vector2.new(1, 0),
                Position = UDim2.new(1, 0, 0, 0),
                Size = UDim2.new(0, 50, 0, 18),
                BackgroundTransparency = 1,
                Font = Theme.Font,
                Text = tostring(value),
                TextColor3 = Theme.Accent,
                TextSize = 14,
                TextXAlignment = Enum.TextXAlignment.Right,
            }, holder)

            local bar = make("Frame", {
                Position = UDim2.new(0, 0, 0, 24),
                Size = UDim2.new(1, 0, 0, 10),
                BackgroundColor3 = Theme.Background,
                BackgroundTransparency = 0.2,
            }, holder)
            addCorner(bar)

            local fill = make("Frame", {
                Size = UDim2.new((value - min) / (max - min), 0, 1, 0),
                BackgroundColor3 = Theme.Accent,
            }, bar)
            addCorner(fill)

            local dragging = false
            local function update(input)
                local rel = math.clamp((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
                value = math.floor(min + (max - min) * rel)
                fill.Size = UDim2.new(rel, 0, 1, 0)
                valueLabel.Text = tostring(value)
                callback(value)
            end

            bar.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = true
                    update(input)
                end
            end)
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = false
                end
            end)
            UserInputService.InputChanged:Connect(function(input)
                if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                    update(input)
                end
            end)

            return {
                Set = function(_, v)
                    v = math.clamp(v, min, max)
                    value = v
                    local rel = (v - min) / (max - min)
                    fill.Size = UDim2.new(rel, 0, 1, 0)
                    valueLabel.Text = tostring(v)
                end,
                Get = function() return value end,
            }
        end

        -- ---------------- DROPDOWN (single) ----------------
        function section:AddDropdown(text, options, default, callback)
            callback = callback or function() end
            options = options or {}
            local selected = default or options[1] or "..."
            local open = false

            local holder = make("Frame", { Size = UDim2.new(1, 0, 0, 32), BackgroundTransparency = 1, ZIndex = 5 }, list)

            local main = make("TextButton", {
                Size = UDim2.new(1, 0, 0, 32),
                BackgroundColor3 = Theme.Background,
                BackgroundTransparency = 0.3,
                Font = Theme.Font,
                Text = "",
                AutoButtonColor = false,
                ZIndex = 5,
            }, holder)
            addCorner(main)

            make("TextLabel", {
                Position = UDim2.new(0, 10, 0, 0),
                Size = UDim2.new(1, -30, 1, 0),
                BackgroundTransparency = 1,
                Font = Theme.Font,
                Text = text,
                TextColor3 = Theme.SubText,
                TextSize = 12,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 5,
            }, main)

            local valueLabel = make("TextLabel", {
                AnchorPoint = Vector2.new(1, 0.5),
                Position = UDim2.new(1, -10, 0.5, 0),
                Size = UDim2.new(0, 100, 1, 0),
                BackgroundTransparency = 1,
                Font = Theme.Font,
                Text = tostring(selected),
                TextColor3 = Theme.Text,
                TextSize = 14,
                TextXAlignment = Enum.TextXAlignment.Right,
                ZIndex = 5,
            }, main)

            local list2 = make("Frame", {
                Position = UDim2.new(0, 0, 0, 36),
                Size = UDim2.new(1, 0, 0, 0),
                AutomaticSize = Enum.AutomaticSize.Y,
                BackgroundColor3 = Theme.Background,
                BackgroundTransparency = 0.1,
                Visible = false,
                ZIndex = 6,
            }, holder)
            addCorner(list2)
            make("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder }, list2)
            make("UIPadding", { PaddingTop = UDim.new(0, 4), PaddingBottom = UDim.new(0, 4) }, list2)

            for _, opt in ipairs(options) do
                local optBtn = make("TextButton", {
                    Size = UDim2.new(1, 0, 0, 26),
                    BackgroundTransparency = 1,
                    Font = Theme.Font,
                    Text = tostring(opt),
                    TextColor3 = Theme.SubText,
                    TextSize = 13,
                    ZIndex = 6,
                }, list2)
                optBtn.MouseEnter:Connect(function() optBtn.TextColor3 = Theme.Text end)
                optBtn.MouseLeave:Connect(function() optBtn.TextColor3 = Theme.SubText end)
                optBtn.MouseButton1Click:Connect(function()
                    selected = opt
                    valueLabel.Text = tostring(opt)
                    open = false
                    list2.Visible = false
                    callback(opt)
                end)
            end

            main.MouseButton1Click:Connect(function()
                open = not open
                list2.Visible = open
            end)

            return { Set = function(_, v) selected = v; valueLabel.Text = tostring(v) end, Get = function() return selected end }
        end

        -- ---------------- MULTI-DROPDOWN ----------------
        function section:AddMultiDropdown(text, options, defaults, callback)
            callback = callback or function() end
            options = options or {}
            local selected = {}
            for _, v in ipairs(defaults or {}) do selected[v] = true end
            local open = false

            local holder = make("Frame", { Size = UDim2.new(1, 0, 0, 32), BackgroundTransparency = 1, ZIndex = 5 }, list)

            local main = make("TextButton", {
                Size = UDim2.new(1, 0, 0, 32),
                BackgroundColor3 = Theme.Background,
                BackgroundTransparency = 0.3,
                Font = Theme.Font,
                Text = "",
                AutoButtonColor = false,
                ZIndex = 5,
            }, holder)
            addCorner(main)

            make("TextLabel", {
                Position = UDim2.new(0, 10, 0, 0),
                Size = UDim2.new(1, -30, 1, 0),
                BackgroundTransparency = 1,
                Font = Theme.Font,
                Text = text,
                TextColor3 = Theme.SubText,
                TextSize = 12,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 5,
            }, main)

            local valueLabel = make("TextLabel", {
                AnchorPoint = Vector2.new(1, 0.5),
                Position = UDim2.new(1, -10, 0.5, 0),
                Size = UDim2.new(0, 140, 1, 0),
                BackgroundTransparency = 1,
                Font = Theme.Font,
                Text = "",
                TextColor3 = Theme.Text,
                TextSize = 13,
                TextTruncate = Enum.TextTruncate.AtEnd,
                TextXAlignment = Enum.TextXAlignment.Right,
                ZIndex = 5,
            }, main)

            local function refreshLabel()
                local names = {}
                for _, opt in ipairs(options) do
                    if selected[opt] then table.insert(names, tostring(opt)) end
                end
                valueLabel.Text = #names > 0 and table.concat(names, ", ") or "Nenhum"
            end
            refreshLabel()

            local list2 = make("Frame", {
                Position = UDim2.new(0, 0, 0, 36),
                Size = UDim2.new(1, 0, 0, 0),
                AutomaticSize = Enum.AutomaticSize.Y,
                BackgroundColor3 = Theme.Background,
                BackgroundTransparency = 0.1,
                Visible = false,
                ZIndex = 6,
            }, holder)
            addCorner(list2)
            make("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder }, list2)
            make("UIPadding", { PaddingTop = UDim.new(0, 4), PaddingBottom = UDim.new(0, 4) }, list2)

            for _, opt in ipairs(options) do
                local optBtn = make("TextButton", {
                    Size = UDim2.new(1, 0, 0, 26),
                    BackgroundTransparency = 1,
                    Font = Theme.Font,
                    Text = "  " .. tostring(opt),
                    TextColor3 = selected[opt] and Theme.Accent or Theme.SubText,
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    ZIndex = 6,
                }, list2)
                optBtn.MouseButton1Click:Connect(function()
                    selected[opt] = not selected[opt]
                    optBtn.TextColor3 = selected[opt] and Theme.Accent or Theme.SubText
                    refreshLabel()
                    callback(selected)
                end)
            end

            main.MouseButton1Click:Connect(function()
                open = not open
                list2.Visible = open
            end)

            return { Get = function() return selected end }
        end

        -- ---------------- INPUT (TEXTBOX) ----------------
        function section:AddInput(text, placeholder, callback)
            callback = callback or function() end
            local holder = make("Frame", { Size = UDim2.new(1, 0, 0, 32), BackgroundTransparency = 1 }, list)

            make("TextLabel", {
                Size = UDim2.new(0.4, 0, 1, 0),
                BackgroundTransparency = 1,
                Font = Theme.Font,
                Text = text,
                TextColor3 = Theme.Text,
                TextSize = 14,
                TextXAlignment = Enum.TextXAlignment.Left,
            }, holder)

            local box = make("TextBox", {
                AnchorPoint = Vector2.new(1, 0),
                Position = UDim2.new(1, 0, 0, 0),
                Size = UDim2.new(0.55, 0, 1, 0),
                BackgroundColor3 = Theme.Background,
                BackgroundTransparency = 0.3,
                Font = Theme.Font,
                PlaceholderText = placeholder or "",
                Text = "",
                TextColor3 = Theme.Text,
                PlaceholderColor3 = Theme.SubText,
                TextSize = 13,
                ClearTextOnFocus = false,
            }, holder)
            addCorner(box)
            make("UIPadding", { PaddingLeft = UDim.new(0, 8) }, box)

            box.FocusLost:Connect(function(enterPressed)
                callback(box.Text, enterPressed)
            end)

            return box
        end

        -- ---------------- KEYBIND ----------------
        function section:AddKeybind(text, defaultKey, callback)
            callback = callback or function() end
            local currentKey = defaultKey or Enum.KeyCode.Unknown
            local listening = false

            local holder = make("Frame", { Size = UDim2.new(1, 0, 0, 32), BackgroundTransparency = 1 }, list)

            make("TextLabel", {
                Size = UDim2.new(1, -100, 1, 0),
                BackgroundTransparency = 1,
                Font = Theme.Font,
                Text = text,
                TextColor3 = Theme.Text,
                TextSize = 14,
                TextXAlignment = Enum.TextXAlignment.Left,
            }, holder)

            local keyBtn = make("TextButton", {
                AnchorPoint = Vector2.new(1, 0.5),
                Position = UDim2.new(1, 0, 0.5, 0),
                Size = UDim2.new(0, 90, 0, 26),
                BackgroundColor3 = Theme.Background,
                BackgroundTransparency = 0.3,
                Font = Theme.Font,
                Text = currentKey.Name,
                TextColor3 = Theme.Accent,
                TextSize = 13,
                AutoButtonColor = false,
            }, holder)
            addCorner(keyBtn)

            keyBtn.MouseButton1Click:Connect(function()
                if listening then return end
                listening = true
                keyBtn.Text = "..."
                local conn
                conn = UserInputService.InputBegan:Connect(function(input, gpe)
                    if input.UserInputType == Enum.UserInputType.Keyboard then
                        currentKey = input.KeyCode
                        keyBtn.Text = currentKey.Name
                        listening = false
                        conn:Disconnect()
                        callback(currentKey)
                    end
                end)
            end)

            return {
                Set = function(_, key) currentKey = key; keyBtn.Text = key.Name end,
                Get = function() return currentKey end,
            }
        end

        -- ---------------- COLOR PICKER (simplificado, RGB via 3 sliders) ----------------
        function section:AddColorPicker(text, defaultColor, callback)
            callback = callback or function() end
            local color = defaultColor or Color3.fromRGB(0, 200, 0)
            local open = false

            local holder = make("Frame", { Size = UDim2.new(1, 0, 0, 32), BackgroundTransparency = 1, ClipsDescendants = false }, list)

            make("TextLabel", {
                Size = UDim2.new(1, -50, 1, 0),
                BackgroundTransparency = 1,
                Font = Theme.Font,
                Text = text,
                TextColor3 = Theme.Text,
                TextSize = 14,
                TextXAlignment = Enum.TextXAlignment.Left,
            }, holder)

            local preview = make("TextButton", {
                AnchorPoint = Vector2.new(1, 0.5),
                Position = UDim2.new(1, 0, 0.5, 0),
                Size = UDim2.new(0, 40, 0, 22),
                BackgroundColor3 = color,
                Text = "",
                AutoButtonColor = false,
            }, holder)
            addCorner(preview)
            addStroke(preview, 1)

            local panel = make("Frame", {
                Position = UDim2.new(0, 0, 0, 36),
                Size = UDim2.new(1, 0, 0, 110),
                BackgroundColor3 = Theme.Background,
                BackgroundTransparency = 0.1,
                Visible = false,
                ZIndex = 6,
            }, holder)
            addCorner(panel)
            make("UIPadding", { PaddingLeft = UDim.new(0, 8), PaddingRight = UDim.new(0, 8), PaddingTop = UDim.new(0, 8) }, panel)
            make("UIListLayout", { Padding = UDim.new(0, 4), SortOrder = Enum.SortOrder.LayoutOrder }, panel)

            local r, g, b = math.floor(color.R * 255), math.floor(color.G * 255), math.floor(color.B * 255)

            local function makeChannel(labelText, initial, onChange)
                local row = make("Frame", { Size = UDim2.new(1, 0, 0, 28), BackgroundTransparency = 1 }, panel)
                make("TextLabel", {
                    Size = UDim2.new(0, 16, 1, 0), BackgroundTransparency = 1, Font = Theme.Font,
                    Text = labelText, TextColor3 = Theme.SubText, TextSize = 12,
                }, row)
                local bar = make("Frame", {
                    Position = UDim2.new(0, 20, 0.5, -4), Size = UDim2.new(1, -20, 0, 8),
                    BackgroundColor3 = Theme.BackgroundAlt,
                }, row)
                addCorner(bar)
                local fill = make("Frame", { Size = UDim2.new(initial / 255, 0, 1, 0), BackgroundColor3 = Theme.Accent }, bar)
                addCorner(fill)

                local dragging = false
                local function update(input)
                    local rel = math.clamp((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
                    fill.Size = UDim2.new(rel, 0, 1, 0)
                    onChange(math.floor(rel * 255))
                end
                bar.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        dragging = true
                        update(input)
                    end
                end)
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        dragging = false
                    end
                end)
                UserInputService.InputChanged:Connect(function(input)
                    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                        update(input)
                    end
                end)
            end

            makeChannel("R", r, function(v) r = v; color = Color3.fromRGB(r, g, b); preview.BackgroundColor3 = color; callback(color) end)
            makeChannel("G", g, function(v) g = v; color = Color3.fromRGB(r, g, b); preview.BackgroundColor3 = color; callback(color) end)
            makeChannel("B", b, function(v) b = v; color = Color3.fromRGB(r, g, b); preview.BackgroundColor3 = color; callback(color) end)

            preview.MouseButton1Click:Connect(function()
                open = not open
                panel.Visible = open
            end)

            return { Set = function(_, c) color = c; preview.BackgroundColor3 = c end, Get = function() return color end }
        end

        -- ---------------- PARAGRAPH ----------------
        function section:AddParagraph(title, desc)
            local holder = make("Frame", { Size = UDim2.new(1, 0, 0, 0), AutomaticSize = Enum.AutomaticSize.Y, BackgroundTransparency = 1 }, list)
            make("TextLabel", {
                Size = UDim2.new(1, 0, 0, 18),
                BackgroundTransparency = 1,
                Font = Theme.Font,
                Text = title,
                TextColor3 = Theme.Text,
                TextSize = 14,
                TextXAlignment = Enum.TextXAlignment.Left,
            }, holder)
            make("TextLabel", {
                Position = UDim2.new(0, 0, 0, 18),
                Size = UDim2.new(1, 0, 0, 0),
                AutomaticSize = Enum.AutomaticSize.Y,
                BackgroundTransparency = 1,
                Font = Theme.Font,
                Text = desc,
                TextColor3 = Theme.SubText,
                TextSize = 12,
                TextWrapped = true,
                TextXAlignment = Enum.TextXAlignment.Left,
            }, holder)
            return holder
        end

        -- ---------------- DIVIDER ----------------
        function section:AddDivider()
            local line = make("Frame", {
                Size = UDim2.new(1, 0, 0, 1),
                BackgroundColor3 = Theme.Stroke,
                BackgroundTransparency = 0.3,
            }, list)
            return line
        end

        -- ---------------- LABEL ----------------
        function section:AddLabel(text)
            local lbl = make("TextLabel", {
                Size = UDim2.new(1, 0, 0, 18),
                BackgroundTransparency = 1,
                Font = Theme.Font,
                Text = text,
                TextColor3 = Theme.SubText,
                TextSize = 13,
                TextXAlignment = Enum.TextXAlignment.Left,
                TextWrapped = true,
            }, list)
            return lbl
        end

        table.insert(tab.Sections, section)
        return section
    end

    return tab
end

return Library

