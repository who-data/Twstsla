-- TEMA (extraído da paleta real: preto/cinza monocromático)
------------------------------------------------------------
local Theme = {
    Background   = Color3.fromRGB(0, 0, 0),
    Panel        = Color3.fromRGB(40, 40, 40),
    PanelDark    = Color3.fromRGB(24, 24, 24),
    Switch       = Color3.fromRGB(240, 240, 240),
    SwitchOff    = Color3.fromRGB(50, 50, 50),
    Knob         = Color3.fromRGB(0, 0, 0),
    KnobOff      = Color3.fromRGB(230, 230, 230),
    Accent       = Color3.fromRGB(255, 0, 0),
    Text         = Color3.fromRGB(255, 255, 255),
    SubText      = Color3.fromRGB(150, 150, 150),
    Stroke       = Color3.fromRGB(40, 40, 40),
    Font         = Enum.Font.GothamMedium,
    FontBold     = Enum.Font.GothamBold,
}

------------------------------------------------------------
-- HELPERS
------------------------------------------------------------
local function create(class, props, children)
    local inst = Instance.new(class)
    for k, v in pairs(props or {}) do inst[k] = v end
    for _, child in ipairs(children or {}) do child.Parent = inst end
    return inst
end

local function tween(inst, props, time, style, dir)
    local t = TweenService:Create(inst, TweenInfo.new(time or 0.18, style or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out), props)
    t:Play()
    return t
end

local function corner(radius, scale)
    if scale then
        return create("UICorner", {CornerRadius = UDim.new(1, 0)})
    end
    return create("UICorner", {CornerRadius = UDim.new(0, radius or 4)})
end

local function stroke(color, thickness)
    return create("UIStroke", {Color = color or Theme.Stroke, Thickness = thickness or 1})
end

local function vgradient(c1, c2, rotation)
    return create("UIGradient", {
        Color = ColorSequence.new(c1, c2),
        Rotation = rotation or 90,
    })
end

local function makeDraggable(frame, dragHandle)
    local dragging, dragStart, startPos
    dragHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    dragHandle.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            if dragging then
                local delta = input.Position - dragStart
                frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            end
        end
    end)
end

------------------------------------------------------------
-- LIBRARY
------------------------------------------------------------
local Library = {}
Library.__index = Library
Library.Flags = {}
Library.Elements = {}
Library.ConfigFolder = "UILibConfigs"

------------------------------------------------------------
-- CONFIG: SAVE / LOAD
------------------------------------------------------------
local function ensureFolder()
    if not isfolder(Library.ConfigFolder) then makefolder(Library.ConfigFolder) end
end

function Library:SaveConfig(name)
    local ok, err = pcall(function()
        ensureFolder()
        writefile(Library.ConfigFolder .. "/" .. name .. ".json", HttpService:JSONEncode(Library.Flags))
    end)
    return ok, err
end

function Library:LoadConfig(name)
    local ok, err = pcall(function()
        local path = Library.ConfigFolder .. "/" .. name .. ".json"
        if not isfile(path) then error("Config não encontrada: " .. name) end
        local data = HttpService:JSONDecode(readfile(path))
        for flag, value in pairs(data) do
            Library.Flags[flag] = value
            local el = Library.Elements[flag]
            if el and el.Set then el.Set(value) end
        end
    end)
    return ok, err
end

function Library:ListConfigs()
    local list = {}
    pcall(function()
        ensureFolder()
        for _, file in ipairs(listfiles(Library.ConfigFolder)) do
            local name = file:match("([^/\\]+)%.json$")
            if name then table.insert(list, name) end
        end
    end)
    return list
end

function Library:DeleteConfig(name)
    return pcall(function() delfile(Library.ConfigFolder .. "/" .. name .. ".json") end)
end

