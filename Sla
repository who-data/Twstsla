        ------------------------------------------------------------
        -- TOGGLE
        ------------------------------------------------------------
        function Tab:CreateToggle(opt)
            opt = opt or {}
            local flag = opt.Flag or opt.Name
            local state = (opt.Default == true)
            Library.Flags[flag] = state

            local Holder = create("TextButton", {
                Size = UDim2.new(1, 0, 0, 34),
                BackgroundColor3 = Theme.Panel,
                Text = "",
                AutoButtonColor = false,
            }, {corner(6), stroke()})
            Holder.Parent = TabPage

            create("TextLabel", {
                Text = opt.Name or "Toggle",
                Font = Theme.Font,
                TextSize = 13,
                TextColor3 = Theme.Text,
                BackgroundTransparency = 1,
                Size = UDim2.new(1, -60, 1, 0),
                Position = UDim2.new(0, 12, 0, 0),
                TextXAlignment = Enum.TextXAlignment.Left,
            }).Parent = Holder

            local Switch = create("Frame", {
                Size = UDim2.fromOffset(38, 20),
                Position = UDim2.new(1, -50, 0.5, 0),
                AnchorPoint = Vector2.new(0, 0.5),
                BackgroundColor3 = state and Theme.Accent or Theme.PanelLight,
            }, {corner(10)})
            Switch.Parent = Holder

            local Knob = create("Frame", {
                Size = UDim2.fromOffset(16, 16),
                Position = state and UDim2.new(1, -18, 0.5, 0) or UDim2.new(0, 2, 0.5, 0),
                AnchorPoint = Vector2.new(0, 0.5),
                BackgroundColor3 = Theme.Text,
            }, {corner(8)})
            Knob.Parent = Switch

            local function setState(newState, fireCallback)
                state = newState
                Library.Flags[flag] = state
                tween(Switch, {BackgroundColor3 = state and Theme.Accent or Theme.PanelLight}, 0.15)
                tween(Knob, {Position = state and UDim2.new(1, -18, 0.5, 0) or UDim2.new(0, 2, 0.5, 0)}, 0.15)
                if fireCallback ~= false and opt.Callback then opt.Callback(state) end
            end

            Holder.MouseButton1Click:Connect(function() setState(not state) end)

            Library.Elements[flag] = {Set = function(v) setState(v, false) end}
            if opt.Callback and opt.Default ~= nil then opt.Callback(state) end

            return {Set = setState}
        end

        ------------------------------------------------------------
        -- SLIDER
        ------------------------------------------------------------
        function Tab:CreateSlider(opt)
            opt = opt or {}
            local flag = opt.Flag or opt.Name
            local min, max = opt.Min or 0, opt.Max or 100
            local value = opt.Default or min
            Library.Flags[flag] = value

            local Holder = create("Frame", {
                Size = UDim2.new(1, 0, 0, 46),
                BackgroundColor3 = Theme.Panel,
            }, {corner(6), stroke()})
            Holder.Parent = TabPage

            create("TextLabel", {
                Text = opt.Name or "Slider",
                Font = Theme.Font,
                TextSize = 13,
                TextColor3 = Theme.Text,
                BackgroundTransparency = 1,
                Size = UDim2.new(1, -50, 0, 20),
                Position = UDim2.new(0, 12, 0, 4),
                TextXAlignment = Enum.TextXAlignment.Left,
            }).Parent = Holder

            local ValueLabel = create("TextLabel", {
                Text = tostring(value),
                Font = Theme.Font,
                TextSize = 12,
                TextColor3 = Theme.SubText,
                BackgroundTransparency = 1,
                Size = UDim2.new(0, 40, 0, 20),
                Position = UDim2.new(1, -46, 0, 4),
                TextXAlignment = Enum.TextXAlignment.Right,
            })
            ValueLabel.Parent = Holder

            local Track = create("Frame", {
                Size = UDim2.new(1, -24, 0, 6),
                Position = UDim2.new(0, 12, 1, -16),
                BackgroundColor3 = Theme.PanelLight,
            }, {corner(3)})
            Track.Parent = Holder

            local Fill = create("Frame", {
                Size = UDim2.new((value - min) / (max - min), 0, 1, 0),
                BackgroundColor3 = Theme.Accent,
            }, {corner(3)})
            Fill.Parent = Track

            local function setValue(v, fireCallback)
                v = math.clamp(v, min, max)
                value = v
                Library.Flags[flag] = v
                ValueLabel.Text = tostring(math.floor(v * 100) / 100)
                Fill.Size = UDim2.new((v - min) / (max - min), 0, 1, 0)
                if fireCallback ~= false and opt.Callback then opt.Callback(v) end
            end

            local dragging = false
            Track.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = true
                end
            end)
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = false
                end
            end)
            UserInputService.InputChanged:Connect(function(input)
                if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                    local rel = math.clamp((input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
                    setValue(min + (max - min) * rel)
                end
            end)

            Library.Elements[flag] = {Set = function(v) setValue(v, false) end}

            return {Set = setValue}
        end

